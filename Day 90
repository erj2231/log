                min = elapsed / 60
                print(f"\nGone Minutes: {min if min < 60 else min/60}")
                print(f"\nPROGRESS: {i}/{steps} | Speed: {sec_per_step:.1f}s/step")
                print(f"EST. REMAINING: {remaining_min:.1f} minutes ({remaining_min/60:.1f} hours)")

            # as we do this every 200 we / on 200
            vloss = val(gpt, token_data2, batch, block, 20, device, dtype)
            vloss2 = val(gpt, token_data, batch, block, 20, device, dtype)
            print(f'Wiki Loss {vloss:.4f} | Corpus Loss {vloss2:.4f}')

            # frees data up
            writer.flush()
            # saving progress
            temp_path = checkpoint_path + ".tmp"
            checkpoint_model = gpt._orig_mod if hasattr(gpt, '_orig_mod') else gpt
            torch.save({
                'step': i,
                'model_state_dict': checkpoint_model.state_dict(),
                'optimizer_state_dict': optimizer.state_dict(),
                'loss': loss.item(),
            }, temp_path)
            os.replace(temp_path, checkpoint_path) 
            print(f"CORE BACKUP SAVED.")
        
        # diagnostics
        if i % 500 == 0 and i > start_step:
            print(f'\n--- [STEP {i}] SOVEREIGN HEALTH REPORT ---')
            has_grad = any(p.grad is not None for p in gpt.parameters())
            print(f"SANITY CHECK: {'Gradients flowing' if has_grad else 'CRITICAL: NO GRADIENTS'}")

            # first i check experts and kick
            if 'routes' in locals() and routes:
                all_router_probs = torch.cat([torch.softmax(r.view(-1, experts), dim=-1) for r in routes if r is not None])
                # flatten as in generate
                avg_usage = all_router_probs.mean(dim=0)
                # check weirdness as in generate
                entropy = -torch.sum(avg_usage * torch.log(avg_usage + 1e-10)).item()
                writer.add_scalar('Metrics/Expert_Entropy', entropy, i)
                all_params = dict(gpt.named_parameters())
                for idx, usage in enumerate(avg_usage):
                    if usage < (1.0 / experts) * 0.1:
                        status = "IDLE (STARVING)"
                        for name, param in all_params.items():
                            if f'experts.{idx}.' in name:
                                # adding noise to move it
                                param.add_(torch.randn_like(param) * 0.001)
                    
                    elif usage > (1.0 / experts) * 1.5:
                        # doing nothing as it will correct on its own
                        status = 'OVERLOADED'
                    else:
                        status = "ACTIVE"
                    print(f"Expert {idx}: [{status}] | Load: {usage:.2%} ")
                    writer.add_scalar(f'Expert_Usage/Expert_{idx}', usage, i)

            # i check overall norm alog router after kicking
            for name, param in gpt.named_parameters():
                writer.add_histogram(f'Weights/{name}', param, i)
                if 'router' in name and param.grad is not None:
                    gnorm = torch.norm(param.grad).item()
                    # checking router entropy
                    if gnorm > 10.0:
                        print(f"!!! ROUTER UNSTABLE: {name} | Grad {gnorm:.2f} | Scaling...")
                        # multiplying on 0.1 to stabilize
                        param.grad.data.mul_(0.1)
                if any(k in name for k in ['expert', 'router', 'A_log']):
                    norm = torch.norm(param).item()
                    # values must be > 1e-3
                    if norm < 1e-3:
                        print(f"!!! COLLAPSE: {name} | Kicking with Gaussian Noise...")
                        param.add_(torch.randn_like(param) * 0.02)
                    # if a_log becomes too big then we reset it
                    if 'A_log' in name and param.mean() > -0.1:
                        print(f"--- RESETTING LRU MEMORY: {name} ---")
                        param.copy_(torch.linspace(-1.0, -2.0, param.size(0)).to(device))
            
            # now we check ram
            ram_p = psutil.virtual_memory().percent
            writer.add_scalar('System/RAM_Usage', ram_p, i)
            if ram_p > 85:
                print(f'RAM CRITICAL!!! RESETTING DYNAMO')
                torch._dynamo.reset()
            print(">>> [THERMAL GUARD] Cooling 120s")
            time.sleep(120)
            data_queue.get()
            start_time += 120

