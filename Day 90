def val(model, data, batch, block, iters, device, dtype):
    model.eval()
    losses = torch.zeros(iters)
    print(f'-> VALIDATING: Sampling {iters} batches...')
    for k in range(iters):
        xb, yb1, _ = get_batch(data, block, batch)
        # doing in 16 if possible
        with torch.amp.autocast(device_type=device.type, dtype=dtype):
            logits, _, _, _, _, _ = model(xb, step=0, tau=0.1)
            loss = F.cross_entropy(logits.view(-1, 4096), yb1.view(-1))
            losses[k] = loss.item()
        # freeing xb and yb1 spaces now
        del xb, yb1
    model.train()
    return losses.mean()

class rms(nn.Module):
    def __init__(self, dim, eps=1e-6):
        super().__init__()
        self.eps = eps
        # regulatory param to give space for model
        self.weight = nn.Parameter(torch.ones(dim))
    
    def forward(self, x):
        # rsqrt pow2 can be done only in float32
        x = x.to(torch.float32)
        # [B, T, 256] -> [B, T, 256]
        normx = x * torch.rsqrt(x.pow(2).mean(-1, keepdim=True) + self.eps)
        return normx.to(torch.float16) * self.weight

class fsqlora(nn.Module):
    def __init__(self, base_linear, rank=4, alpha=1.0, levels=[8, 5, 5]):
        super().__init__()
        self.base_linear = base_linear
        self.levels = levels
        self.rank = rank
        self.scaling = alpha / rank
        # lora
        self.loraa = nn.Parameter(torch.empty(base_linear.in_features, rank))
        self.lorab = nn.Parameter(torch.empty(rank, base_linear.out_features))
        # radix
        basis = torch.ones(len(levels), dtype=torch.long)
        for i in range(1, len(levels)):
            basis[i] = basis[i-1] * levels[i-1]
        self.register_buffer("basis", basis)
        nn.init.kaiming_uniform_(self.loraa, a=math.sqrt(5))
        nn.init.zeros_(self.lorab)

    def get_adapted_weight(self, out_slice=None, in_slice=None):
        # 1. slicing automated
        w = self.base_linear.weight
        if out_slice is not None or in_slice is not None:
            w = w[:out_slice, :in_slice]
        # 2. FSQ + STE (Rounding like in bit)
        z_q = torch.round(w + (torch.randn_like(w) - 0.5)).clamp(0, len(self.levels) - 1)
        wq = w + (z_q - w).detach()
        # 3. LoRA Delta (lorab @ loraa.T)
        # Slicing A and B to match the active weight dims
        l_a = self.loraa[:in_slice, :] if in_slice else self.loraa
        l_b = self.lorab[:, :out_slice] if out_slice else self.lorab
        lora_delta = (l_b @ l_a.t()) * self.scaling
        return wq + lora_delta
    # Helper for quantizing activations (xactive)
    def quantize_val(self, x, levels):
        z_q = torch.round(x + (torch.randn_like(x) - 0.5)).clamp(0, len(levels) - 1)
        return x + (z_q - x).detach()

class mrrope(nn.Module):
    def __init__(self, rdim, len=512):
        super().__init__()
        # all spectrum
        inv_freq = 1.0 / (10000 ** (torch.arange(0, rdim, 2).float() / rdim))
        # range of len
        t = torch.arange(len).float()
        # putting range onto that spectrum
        freqs = torch.outer(t, inv_freq)
        # preparing for both cos and sin
        emb = torch.cat((freqs, freqs), dim=-1)
        # registering static universe
        self.register_buffer("cos", emb.cos().view(1, len, rdim))
        self.register_buffer("sin", emb.sin().view(1, len, rdim))
    
    def rotatehalf(self, x, c, s):
        # chunk much faster than interleaved
        x1, x2 = x.chunk(2, dim=-1)
        # multiplying everything in cat is much more tactical
        return torch.cat([x1 * c - x2 * s, x2 * c + x1 * s], dim=-1)
    
    def forward(self, q, k):
        T = q.shape[1]
        # [1, T, 384] -> [1, T, 1, 384]
        # by :T we save ram
        cos = self.cos[:, :T, :].unsqueeze(2).to(q.dtype)
        sin = self.sin[:, :T, :].unsqueeze(2).to(q.dtype)
        # [B, T, H, 384] * [1, T, 1, 384] -> [B, T, H, 384]
        return self.rotatehalf(q, cos, sin), self.rotatehalf(k, cos, sin)

class newmla(nn.Module):
    def __init__(self, emb, n_heads=8, latent_dim=64, rope_dim=32):
        super().__init__()
        self.latent = latent_dim
        self.n_heads = n_heads
        # dim on 1 head
        self.head_dim = emb // n_heads
        self.rope_dim = rope_dim
        # norm before up
        self.norm = rms(emb)
        # Wrapping projections in fsqlora to enable LoRA adapters + Quantized base
        self.kv_down = fsqlora(nn.Linear(emb, latent_dim, bias=False))
        self.kv_up = fsqlora(nn.Linear(latent_dim, n_heads * (self.head_dim + rope_dim + self.head_dim), bias=False))
        # better to init one big then split
        self.q_proj = fsqlora(nn.Linear(emb, n_heads * (self.head_dim + rope_dim), bias=False))
        self.out_proj = fsqlora(nn.Linear(n_heads * self.head_dim, emb, bias=False))
        # ultimate scale of content + position
        self.scale = (self.head_dim + rope_dim) ** -0.5
        # 0.1 as i want normal distribution in kvdown
        # Accessing .base_linear.weight because fsqlora wraps the layer
        nn.init.xavier_uniform_(self.kv_down.base_linear.weight, gain=0.1)
        nn.init.xavier_uniform_(self.kv_up.base_linear.weight)
        nn.init.xavier_uniform_(self.q_proj.base_linear.weight)
        # final residual
        nn.init.xavier_uniform_(self.out_proj.base_linear.weight, gain=0.02)

    def forward(self, x, rope_obj, active4, grid_levels=[8, 5, 5]):
        # [B, T, 384]
        B, T, _ = x.shape
        # slicing input to matryoshka size
        x = x[:, :, :active4]
        # bit them - Quantizing input activation
        xactive = self.kv_down.quantize_val(x, levels=[16, 16, 16])
        # Getting Adapted Weights (Quantized Base Weight + LoRA Delta)
        # Slicing is handled inside get_adapted_weight to match Matryoshka/Latent dims
        wq_down = self.kv_down.get_adapted_weight(out_slice=self.latent, in_slice=active4)
        wq_up = self.kv_up.get_adapted_weight(out_slice=None, in_slice=self.latent)
        wq_proj = self.q_proj.get_adapted_weight(out_slice=None, in_slice=active4)
        # [B, T, 384] * [384, 64] -> [B, T, 64]
        # compressing x down to save ram
        # Using F.linear with our combined wq_down weight
        z_latent = self.kv_down.quantize_val(self.norm(F.linear(xactive, wq_down)), levels=grid_levels)
        # [B, T, 64] * [64, H * (32 + 32 + 32)] -> [B, T, H, 96]
        # here slicing up weight too as we need all weights to be sliced
        kv_up = F.linear(z_latent, wq_up).view(B, T, self.n_heads, -1)
        # [B, T, H, 96] -> [B, T, H, 32] + [B, T, H, 32] + [B, T, H, 32]
        k_content, k_pe, v = torch.split(kv_up, [self.head_dim, self.rope_dim, self.head_dim], dim=-1)
        # [B, T, 384] * [384, H * (32 + 32)] -> [B, T, H, 64]
        q_up = F.linear(xactive, wq_proj).view(B, T, self.n_heads, -1)
        # [B, T, H, 64] -> [B, T, H, 32] + [B, T, H, 32]
        q_content, q_pe = torch.split(q_up, [self.head_dim, self.rope_dim], dim=-1)
        # i only rotate pe part
        q_pe, k_pe = rope_obj(q_pe, k_pe)
        # [B, T, H, 32] + [B, T, H, 32] -> [B, T, H, 64]
        q, k = torch.cat([q_content, q_pe], dim=-1), torch.cat([k_content, k_pe], dim=-1)
        # [B, T, H, 64] -> [B, H, T, 64]
        q = q.transpose(1, 2)
        # [B, T, H, 64] -> [B, H, T, 64]
        k = k.transpose(1, 2)
        # [B, T, H, 32] -> [B, H, T, 32]
        v = v.transpose(1, 2) 
        # [B, H, T, T] * [B, H, T, 32] -> [B, H, T, 32]
        # sdpa replaces softmax, mask and operations like einsum and scale
        out = F.scaled_dot_product_attention(
            q, k, v, 
            is_causal=True, 
            scale=self.scale
        ) 
        # [B, H, T, 32] -> [B, T, H, 32] -> [B, T, 384]
        # transpose+reshape are glued to next and they only change stride
        # slicing too
        out = out.transpose(1, 2).reshape(B, T, -1)
        # Get adapted weight for output projection
        wo_proj = self.out_proj.get_adapted_weight(out_slice=None, in_slice=None)
        return F.linear(out, wo_proj)

class moe(nn.Module):
    def __init__(self, emb, experts, latent_dim=None):
        super().__init__()
        self.experts = experts
        self.kv_dim = latent_dim or (emb // 4)
        # Wrapping each expert's up and down projection in fsqlora
        # This allows each expert to have its own LoRA adapter
        self.w_q = nn.ModuleList([
            fsqlora(nn.Linear(emb, self.kv_dim, bias=False)) 
            for _ in range(experts)
        ])
        self.w_o = nn.ModuleList([
            fsqlora(nn.Linear(self.kv_dim, emb, bias=False)) 
            for _ in range(experts)
        ])
        # added regulatory parameter for router to choose
        self.bias = nn.Parameter(torch.zeros(experts))
        # Norm for the bottleneck
        self.norm = rms(self.kv_dim)
        nn.init.constant_(self.bias, -1.0)
        # Initialization using the base_linear within the fsqlora wrapper
        with torch.no_grad():
            for e in range(experts):
                nn.init.xavier_uniform_(self.w_q[e].base_linear.weight, gain=0.1)
                # again 0.02 used for final residual layer
                nn.init.xavier_uniform_(self.w_o[e].base_linear.weight, gain=0.02)

    def forward(self, x, route_soft, active4=None, grid_levels=[2, 2]):
        # [B, T, 384]
        B, T, C = x.shape
        # [B, T, C] -> [B*T, C]
        x_flat = x.view(-1, C)
        # bit activations - using the quantization helper from one of the fsqlora instances
        x_q = self.w_q[0].quantize_val(x_flat, levels=[16, 16, 16]) 
        # Slicing logic for Matryoshka MoE
        kv_slice = max(32, active4 // 4)
        # Calculate Router probabilities
        probs = F.softmax((route_soft + self.bias), dim=-1) # [B*T, Experts]
        expert_outputs = []
        for e in range(self.experts):
            # 1. Get adapted weights for this expert (Quantized + LoRA)
            # wq_q: [kv_slice, active4]
            wq_q = self.w_q[e].get_adapted_weight(out_slice=kv_slice, in_slice=active4)
            # wo_q: [active4, kv_slice]
            wo_q = self.w_o[e].get_adapted_weight(out_slice=active4, in_slice=kv_slice)
            # 2. Expert Path
            # [B*T, active4] @ [active4, kv_slice] -> [B*T, kv_slice]
            mid = F.linear(x_q[:, :active4], wq_q)
            mid = F.silu(self.norm(mid))
            # [B*T, kv_slice] @ [kv_slice, active4] -> [B*T, active4]
            out_e = F.linear(mid, wo_q)
            expert_outputs.append(out_e.unsqueeze(1)) # [B*T, 1, active4]
        # Combine all expert outputs
        # [B*T, Experts, active4]
        all_outs = torch.cat(expert_outputs, dim=1)
        # gate_flat: [B*T, Experts, 1]
        gate_flat = probs.view(B*T, self.experts, 1)
        # weighted sum across experts: [B*T, 1, active4]
        final_output = torch.bmm(gate_flat.transpose(1, 2), all_outs)
        # [B*T, 1, active4] -> [B, T, active4]
        return final_output.view(B, T, active4)

class lnn(nn.Module):
    def __init__(self, emb):
        super().__init__()
        # emb * 2 as it takes two inputs
        # Wrapping in fsqlora for bitted weights + LoRA
        self.dt = fsqlora(nn.Linear(emb * 2, emb))
        # Accessing .base_linear.weight because of the wrapper
        nn.init.xavier_uniform_(self.dt.base_linear.weight)
        # -2 is a good gating
        nn.init.constant_(self.dt.base_linear.bias, -2.0)

    def forward(self, h, combined_context, active4=None):
        h = h[:, :, :active4]
        combined_context = combined_context[:, :, :active4]
        combined = torch.cat([combined_context, h], dim=-1)
        # Get adapted weight with specific Matryoshka slicing
        # active4*2 for the concatenated input, active4 for output
        wq_dt = self.dt.get_adapted_weight(out_slice=active4, in_slice=active4*2)
        # [384] @ [384] -> [384]
        # Using F.linear with bitted+lora weight and sliced bias
        dt_logits = F.linear(combined, wq_dt, self.dt.base_linear.bias[:active4])
        dt = torch.sigmoid(dt_logits)
        # [384] + ([384] - [384]) * [384] -> [384]
        # tanh used for bigger spectrum
        return h + (-h + torch.tanh(combined_context)) * dt

class swigluznn(nn.Module):
    def __init__(self, emb):
        super().__init__()
        hidden_dim = int(8/3 * emb)
        # better to init one and split then two
        self.w_combined = fsqlora(nn.Linear(emb, hidden_dim * 2, bias=False))
        self.w_down = fsqlora(nn.Linear(hidden_dim, emb, bias=False))
        with torch.no_grad():
            # 0.1 for gate
            nn.init.xavier_uniform_(self.w_combined.base_linear.weight[:hidden_dim], gain=0.1)
            nn.init.xavier_uniform_(self.w_down.base_linear.weight, gain=0.02)
            # 1.0 for up
            nn.init.xavier_uniform_(self.w_combined.base_linear.weight[hidden_dim:])

    def forward(self, x, active4=None):
        # Slice output to 2 * hidden_dim, input to active4
        # Note: If hidden_dim scales with active4, adjust out_slice accordingly
        wq_combined = self.w_combined.get_adapted_weight(out_slice=None, in_slice=active4)
        combined = F.linear(x[:, :, :active4], wq_combined)
        gate, up = torch.chunk(combined, 2, dim=-1)
        # [B, T, 682] * [B, T, 682] -> [B, T, 682]
        # silu used for smoothness
        hff = F.silu(gate) * up
        # Down project
        wq_down = self.w_down.get_adapted_weight(out_slice=active4, in_slice=None)
        # [B, T, 682] @ [682, 256] -> [B, T, 256]
        return F.linear(hff, wq_down)

class lru(nn.Module):
    def __init__(self, emb, d_state=16):
        super().__init__()
        self.emb = emb
        self.d_state = d_state
        self.dt_rank = 16
        # Grouped conv stays standard as it's small/specialized
        self.conv1d = nn.Conv1d(emb, emb, kernel_size=4, groups=emb, padding=3)
        # Wrap projections
        self.x_proj = fsqlora(nn.Linear(emb, self.dt_rank + d_state * 2, bias=False))
        self.dt_proj = fsqlora(nn.Linear(self.dt_rank, emb, bias=True))
        self.A_log = nn.Parameter(torch.log(torch.arange(1, emb + 1).float()))
        self.state_norm = rms(d_state) 
        nn.init.normal_(self.dt_proj.base_linear.weight, mean=0.0, std=0.01)
        nn.init.dirac_(self.conv1d.weight)
        nn.init.orthogonal_(self.x_proj.base_linear.weight, gain=0.02)
        nn.init.constant_(self.dt_proj.base_linear.bias, -2.0)
        with torch.no_grad():
            self.A_log.copy_(torch.log(torch.linspace(0.001, 0.1, emb)))

    def forward(self, x, training=False, active4=None):
        B_size, T, E = x.shape
        x = x[:, :, :active4]
        # Convolutional path
        # Slicing conv weights manually as fsqlora isn't applied to conv here
        x_conv = F.conv1d(x.transpose(1, 2), self.conv1d.weight[:active4, :1, :], 
                          groups=active4, padding=3).transpose(1, 2)
        x_active = F.silu(x_conv[:, :T, :]) # Ensure T length matches
        # 1. Project to ranks (B, C, DT)
        wq_x = self.x_proj.get_adapted_weight(out_slice=None, in_slice=active4)
        x_db = F.linear(x_active, wq_x)
        dt_raw, b_vals, c_vals = torch.split(x_db, [self.dt_rank, self.d_state, self.d_state], dim=-1)
        # 2. Project DT to embedding dim
        wq_dt = self.dt_proj.get_adapted_weight(out_slice=active4, in_slice=None)
        dtlinear = F.linear(dt_raw, wq_dt, self.dt_proj.base_linear.bias[:active4])
        dt = torch.exp(dtlinear).clamp(max=0.1)
        A = -torch.exp(self.A_log[:active4].float())
        if training:
            log_decay = dt * A.view(1, 1, -1) 
            cum_decay = torch.cumsum(log_decay, dim=1).unsqueeze(-1) 
            term = (x_active * dt).unsqueeze(-1) * b_vals.unsqueeze(2) 
            u_discounted = term * torch.exp(-cum_decay)
            history = torch.cumsum(u_discounted, dim=1)
            state = history * torch.exp(cum_decay)
            y = (state * c_vals.unsqueeze(2)).sum(dim=-1)
            return y
        else: 
            state = torch.zeros(B_size, active4, self.d_state, device=x.device, dtype=x.dtype)
            y_out = torch.empty(B_size, T, active4, device=x.device, dtype=x.dtype)
            for t in range(T): 
                dt_t = dt[:, t, :].unsqueeze(-1) 
                b_t = b_vals[:, t, :].unsqueeze(1) 
                c_t = c_vals[:, t, :].unsqueeze(-1) 
                x_t = x_active[:, t, :].unsqueeze(-1)
                
                decay = torch.exp(dt_t * A.view(1, -1, 1))
                state = state * decay + (dt_t * x_t * b_t)
                state = self.state_norm(state) 
                y_t = torch.matmul(state, c_t).squeeze(-1)
                y_out[:, t, :] = y_t
            return y_out

class heads(nn.Module):
    def __init__(self, emb, vocab, spec_count):
        super().__init__()
        self.embed = nn.Embedding(vocab, emb)
        self.spec_count = spec_count
        # Norms
        self.norm_f = rms(emb)
        self.norm_mtp = rms(emb)
        # Wrapped Projections
        self.gate = fsqlora(nn.Linear(emb, emb))
        self.pred_state = fsqlora(nn.Linear(emb, emb))
        # Multi-Token Prediction Heads
        self.spec_heads = nn.ModuleList([
            fsqlora(nn.Linear(emb, emb)) for _ in range(spec_count)
        ])
        # Final classifier (tied to embed)
        # We don't wrap this in fsqlora because of weight tying, 
        # but we use opo_linear for memory efficiency.
        self.vim = nn.Linear(emb, 1)
        # Inits
        nn.init.normal_(self.embed.weight, mean=0.0, std=0.02)
        nn.init.xavier_uniform_(self.gate.base_linear.weight, gain=0.1)
        nn.init.constant_(self.gate.base_linear.bias, -1.0)
        for h in self.spec_heads:
            nn.init.xavier_uniform_(h.base_linear.weight, gain=0.1)

    def opo_linear(self, x, weight, chunks=4):
        # [V, E] chunked for memory efficiency
        vocab_chunks = torch.chunk(weight, chunks, dim=0)
        logits = [F.linear(x, w_c) for w_c in vocab_chunks]
        return torch.cat(logits, dim=-1)

    def forward(self, h_final, i4=None, active4=None, grid_levels=[8, 5, 5]):
        # [B, T, active4]
        # Quantize inputs using the helper from one of the fsqlora instances
        h_norm = self.gate.quantize_val(self.norm_f(h_final[:, :, :active4]), levels=[16, 16, 16])
        i4_norm = self.gate.quantize_val(self.norm_f(i4[:, :, :active4]), levels=[16, 16, 16])
        # 1. Gate Logic
        wq_gate = self.gate.get_adapted_weight(out_slice=active4, in_slice=active4)
        g = torch.sigmoid(F.linear(h_norm, wq_gate, self.gate.base_linear.bias[:active4]))
        # 2. Prediction State
        wq_pred = self.pred_state.get_adapted_weight(out_slice=active4, in_slice=active4)
        ph = F.linear(i4_norm, wq_pred)
        # [B, T, active4]
        # logic to determine final context before prediction
        combined_context = h_norm + (ph - h_norm) * g
        
        # [B, T, active4] -> [B, T, vocab]
        # Using weight tying with the embedding layer
        logits = self.opo_linear(combined_context, self.embed.weight[:, :active4])
        
        # Multi-Token Prediction (MTP) logic
        spec_logits = []
        for i, head in enumerate(self.spec_heads):
            # Getting adapted weight for each specific head
            wq_head = head.get_adapted_weight(out_slice=active4, in_slice=active4)
            # Projecting current context to future token space
            spec_h = F.linear(combined_context, wq_head)
            spec_h = self.norm_mtp(spec_h)
            # Classifier for spec heads tied to same embedding
            sl = self.opo_linear(spec_h, self.embed.weight[:, :active4])
            spec_logits.append(sl)
            
        return logits, spec_logits, combined_context, g, probs, entropy

class layer(nn.Module):
    def __init__(self, i, emb, experts):
        super().__init__()
        self.i = i
        self.lnn = lnn(emb)
        self.norm1 = rms(emb)
        self.norm2 = rms(emb)
        self.rope = mrrope(rdim=32)
        self.smallparam = nn.Parameter(torch.ones(emb) * 0.1)
        # Expert vs SwiGLU logic
        if i % 2 == 0:
            self.is_expert = True
            self.branch = moe(emb, experts)
            # Router also uses fsqlora for consistency
            self.router = fsqlora(nn.Linear(emb, experts, bias=False))
            nn.init.orthogonal_(self.router.base_linear.weight, gain=0.01)
        else:
            self.is_expert = False
            self.branch = swigluznn(emb)
        # Global (MLA) vs Local (LRU) logic
        if i % 3 == 0:
            self.is_global = True
            self.mla = newmla(emb)
        else:
            self.is_global = False
            self.lrussd = lru(emb)

    def forward(self, h, lrustate, tau, training=False, active4=None):
        hnorm1 = self.norm1(h)
        hnorm2 = self.norm2(h)
        # 1. Context Branch
        if self.is_global:
            h_context = self.mla(hnorm1, self.rope, active4)
            next_state = None
        else:
            h_context, next_state = self.lrussd(lrustate, hnorm1, active4)
        h_context = h + h_context
        # 2. Feedforward / MoE Branch
        if self.is_expert:
            # Get adapted router weight
            wq_router = self.router.get_adapted_weight(out_slice=None, in_slice=active4)
            logits = F.linear(hnorm2[:, :, :active4], wq_router)
            logits = torch.clamp(logits, -30.0, 30.0)
            if training:
                route = F.gumbel_softmax(logits, tau=tau, hard=not training)
            else:
                route = logits.argmax(-1)
            combined_context = self.branch(hnorm2, route, active4)
        else:
            combined_context = self.branch(hnorm2, active4) 
            route = None
        # 3. Liquid Fusion
        h_liquid = self.lnn(h_context, combined_context, active4)
        return h + (h_liquid * self.smallparam[:active4]), next_state, route

class model(nn.Module):
    def __init__(self, vocab, emb, n_layers, n_experts, spec_count=2):
        super().__init__()
        self.emb = emb
        self.embed = nn.Embedding(vocab, emb)
        self.layers = nn.ModuleList([layer(i, emb, n_experts) for i in range(n_layers)])
        self.heads = heads(emb, vocab, spec_count)
        nn.init.normal_(self.embed.weight, std=0.02)
        # Adjusting the MTP input mix param
        self.mtpmix = nn.Parameter(torch.ones(emb) * 0.5)

    def forward(self, x, lru_states=None, tau=1.0, active4=64):
        # Scale embedding
        h = self.embed(x) * (self.emb ** 0.5)
        if lru_states is None: 
            lru_states = [None] * len(self.layers)
        routes = []
        new_states = []
        # First layer pass to establish i4 (residual anchor)
        h, ns, r = self.layers[0](h, lru_states[0], tau, active4=active4)
        i4 = h.clone()
        new_states.append(ns)
        if r is not None: routes.append(r)
        # Core stack
        for i in range(1, len(self.layers)):
            h, ns, r = self.layers[i](h, lru_states[i], tau, active4=active4)
            new_states.append(ns)
            if r is not None: routes.append(r)
        # MTP Mixing
        h = h + (i4 * self.mtpmix[:active4])
        # Heads
        l1, spec, ph, h_final = self.heads(h, i4, active4)
        return l1, spec, ph, h_final, new_states, routes

class generate(nn.Module):
    def __init__(self, model, tokenizer, length, tmp, topk, penalty):
        super().__init__()
        self.model = model
        self.tokenizer = tokenizer
        self.length = length
        self.tmp = max(tmp, 1e-6) 
        self.topk = topk
        self.penalty = penalty

    @torch.no_grad()
    def forward(self, prompt, active4=384): # Default to full dimension
        self.model.eval()
        device = next(self.model.parameters()).device
        input_ids = self.tokenizer.encode(prompt)
        tokens = torch.tensor([input_ids], dtype=torch.long, device=device)
        lru_state = [None] * len(self.model.layers)
        print('\nmodel: ', end='', flush=True)
        history = []
        pen_indices = torch.arange(16, device=device)
        decay = torch.exp(-pen_indices / 3.0) * self.penalty
        for _ in range(self.length):
            # Model returns: l1, spec_chain, ph, h_final, new_states, routes
            out = self.model(tokens, lru_states=lru_state, active4=active4)
            logits1 = out[0][:, -1, :]
            spec_logits_list = out[1]
            lru_state = out[4]
            # 1. Repetition Penalty
            if len(history) > 0:
                h_slice = torch.tensor(history[-16:], device=device)
                logits1[0].index_add_(0, h_slice, -decay[:len(history[-16:])])
                token_counts = torch.bincount(torch.tensor(history[-128:], device=device), minlength=self.model.vocab)
                logits1[0] -= (token_counts.float() ** 1.1) * 0.15
            # 2. Dynamic Temperature via Entropy
            probs_check = F.softmax(logits1 / 2.0, dim=-1)
            entropy = -torch.sum(probs_check * torch.log(probs_check + 1e-9))
            dtmp = torch.clamp(self.tmp + (1.0 / (entropy + 0.5)), self.tmp, 1.5)
            logits1 = logits1 / dtmp
            # 3. Top-K Filtering
            top_v, _ = torch.topk(logits1, self.topk) 
            logits1[logits1 < top_v[:, [-1]]] = -65504.0 # Float16 min
            # 4. Sampling & Speculative Acceptance
            probs = F.softmax(logits1, dim=-1)
            next_token_tensor = torch.multinomial(probs, num_samples=1)
            next_token = next_token_tensor.item()
            accepted_tokens = [next_token]
            history.append(next_token)
            print(self.tokenizer.decode([next_token]), end='', flush=True)
            # Speculative chain verification
            for future_logits in spec_logits_list:
                f_logits = future_logits[:, -1, :]
                f_probs = F.softmax(f_logits, dim=-1)
                conf, best_token = torch.max(f_probs, dim=-1)
                # Heuristic: only accept if confidence is high (low 'cost')
                cost = 1.0 / (conf.item() + 1e-5)
                if cost <= 2.0: # Tightened threshold for speculative chain
                    t_idx = best_token.item()
                    accepted_tokens.append(t_idx)
                    history.append(t_idx)
                    print(self.tokenizer.decode([t_idx]), end='', flush=True)
                else:
                    break
            # Update tokens for next pass with the last accepted token
            tokens = torch.tensor([[accepted_tokens[-1]]], dtype=torch.long, device=device)
        return history

