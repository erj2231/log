def love(path, tokens, rules):
    # initializing tokenizer
    tokenizer = bpe(4096)
    # dataset in .parquet
    if path.endswith('.parquet'):
        df = pd.read_parquet(path, columns=['text'])
        text = ' '.join(df['text'].values)
    # if we have both rules and tokens
    if os.path.exists(tokens) and os.path.exists(rules):
        token_data = np.load(tokens)
        with open(rules, 'rb') as f:
            state = pickle.load(f)
            tokenizer.merges = state['merges']
            tokenizer.vocab = state['vocab']
    # if no rules or tokens then train everything and save
    else:        
        with open(path, "r", encoding="utf-8") as f: 
            text = f.read().lower()
        tokenizer.train(text)
        with open(rules, 'wb') as f:
            pickle.dump({'merges': tokenizer.merges, 'vocab': tokenizer.vocab}, f)
        token_data = np.array(tokenizer.encode(text), dtype=np.uint16)
        np.save(tokens, token_data)
    return tokenizer, token_data

