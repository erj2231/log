import torch
import torch.nn as nn
import torch.nn.functional as F
class full(nn.Module):
    def __init__(self, rank=4, alpha=8, block=32, levels=225, wgain=0.02, 
                 again=0.1, experts=8, emb=384, dims=12, layers=24, bott=4):
        super().__init__()
        full = levels * layers * experts
        self.block = block
        self.numb = full // block

        coords = torch.stack(torch.meshgrid(
            torch.linspace(0, 1, levels),
            torch.linspace(0, 1, layers),
            torch.linspace(0, 1, experts),
            indexing='ij'
        ), dim=-1).view(-1, 3) 
        idx = torch.arange(0, self.block // 2).float()
        bases = torch.logspace(4, 6, dims, base=10.0)
        idx = torch.arange(0, self.block // 2).float() 
        maslovshift = torch.sin(coords.sum(dim=-1, 
                                           keepdim=True) * torch.pi) * 0.25
        frequencies = 1.0 / (bases.unsqueeze(1) ** (idx / self.block // 2))
        angles = frequencies.unsqueeze(0) + maslovshift
        spinors = torch.stack([torch.cos(angles), 
                        torch.sin(angles)], dim=-1)
        self.func = nn.Parameter(spinors * wgain)

        self.emb = emb
        self.bottdim = emb // 4
        self.down = nn.Linear(emb, self.bottdim)
        self.up = nn.Linear(self.bottdim, emb)

        self.algebra = nn.Parameter(torch.zeros(emb // 2, emb // 2))
        with torch.no_grad():
            diagvals = torch.linspace(-0.1, 0.1, self.emb // 2)
            self.algebra.fill_(0)
            for i in range(self.emb // 2):
                self.algebra[i, i] = diagvals[i] 
        self.euler = nn.Parameter(torch.full((emb // 2,), 0.1))
        self.eta = nn.Parameter(torch.tensor(0.01))

        self.w = nn.Parameter(torch.randn(emb//2, dtype=torch.complex64))
        self.v = nn.Parameter(torch.randn(emb//2, dtype=torch.complex64))

        self.padep = nn.Parameter(torch.zeros(2))
        self.padeq = nn.Parameter(torch.zeros(2))
        with torch.no_grad():
            self.padeq.fill_(0.01) 

        self.gaugefield = nn.Parameter(torch.randn(emb//2) * 0.01)     
        self.glu = nn.Parameter(torch.randn(emb//2, emb//2) * 0.02)

        self.gamma = nn.Parameter(torch.full((emb//2,), 0.05))
        self.temperature = nn.Parameter(torch.tensor(0.01)) 
        self.dt = 0.1

        self.alphaentropy = nn.Parameter(torch.tensor(0.02))
        self.wavephase = nn.Parameter(torch.randn(emb//2))

        self.weight_real = nn.Parameter(torch.randn(emb//2, self.emb) * 0.02)
        self.weight_imag = nn.Parameter(torch.randn(emb//2, self.emb) * 0.02)

        self.dt = 0.1
        self.momentum_gain = nn.Parameter(torch.ones(emb//2) * 0.99)

        with torch.no_grad():
            realbase = torch.logspace(1, 3, emb//2, base=10.0)
            imagbase = torch.logspace(2, 4, emb//2, base=10.0)
            self.complexlospace = nn.Parameter(torch.complex(realbase, imagbase))

    def forward(self, x):
        B, T, C = x.shape
        xbott = self.down(x)
        xsplit = xbott.view(B, T, self.emb // 2, 2)

        symplectic = self.eta * (xsplit[..., 0] * xsplit[..., 1])
        xcomplex = torch.complex(xsplit[..., 0], xsplit[..., 1] + symplectic)

        padlen = T // 4
        m = max(1, T // 4)
        landmarks = xcomplex[:, ::4, :] 
        nystrom = torch.matmul(xcomplex, landmarks.conj().transpose(
            -1, -2)) / m
        xcomplex = torch.matmul(nystrom, landmarks)
        xcomplexpadded = F.pad(torch.view_as_real(xcomplex).permute(
            0, 3, 1, 2), (0, 0, padlen, padlen), mode='circular')
        xcomplexpadded = torch.complex(xcomplexpadded[:, 0]
                                       , xcomplexpadded[:, 1])
        
        fmm = torch.fft.rfft(xcomplexpadded , n=T + 2 * padlen, dim=1)
        freq = torch.linspace(0, 1, fmm.size(1))
        pade = (1.0 + torch.polyval(self.padep, freq)) / (
            1.0 + torch.polyval(self.padeq, freq) + 1e-6)
        filteredfmm = fmm * pade.unsqueeze(0).unsqueeze(-1)
        outfmm = torch.fft.irfft(filteredfmm , n=T + 2 * padlen, dim=1)
        outfmm = outfmm[:, padlen:-padlen, :]

        cayleyi = torch.eye(self.emb // 2)
        lie = self.algebra - self.algebra.t() 
        cayley = torch.matmul(cayleyi - lie, torch.inverse(cayleyi + lie))
        duplicate = cayley.unsqueeze(0).unsqueeze(0).repeat(B, T, 1, 1)
        paralscan = torch.linalg.cumprod(duplicate, dim=1)
        mimo = torch.matmul(outfmm.unsqueeze(-2), paralscan).squeeze(-2)
        
        q = torch.real(mimo)
        p = torch.imag(mimo)
        noise = torch.randn_like(p) * torch.sqrt(2 * self.gamma 
                                                 * self.temperature * self.dt)
        q_next = q + self.dt * p 
        p_next = p + self.dt * (-q_next) - (self.gamma * p) + noise
        mimo = torch.complex(q_next, p_next)

        mimomagsq = torch.real(mimo * mimo.conj()) + 1e-8
        prob = mimomagsq / (mimomagsq.sum(dim=-1, keepdim=True) + 1e-8)
        wirtingerentrgrad = mimo * (torch.log(prob) + 1.0)
        mimo = mimo - self.alphaentropy * wirtingerentrgrad

        refwave = torch.exp(1j * self.wavephase).unsqueeze(0).unsqueeze(0)
        interferencerms = torch.sqrt(
            0.5 * (mimomagsq + 1.0 + 2.0 * torch.real(mimo * refwave.conj())) + 1e-6
        )
        mimo = mimo * interferencerms

        euler = torch.exp(1j * self.euler)
        roots = torch.exp(2j * torch.pi * torch.arange(
            self.emb // 2) / self.emb)
        winding = torch.cumsum(torch.diag(self.algebra), dim=0)
        maslovindex = torch.floor(winding / (2 * torch.pi))
        berry = torch.complex(torch.cos(winding), torch.sin(winding))

        gate = torch.sigmoid(torch.real(
