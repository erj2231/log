def loadbalance(routes, experts, training=False):
    valid_tensors = []
    for r in routes:
        if r is not None and torch.is_tensor(r):
            if r.dim() >= 2 and r.shape[-1] == experts:
                valid_tensors.append(r.view(-1, experts))
            elif r.dim() == 1 and r.numel() % experts == 0 and r.numel() > 0:
                valid_tensors.append(r.view(-1, experts))
                
    allroutes = torch.cat(valid_tensors, dim=0)
    importance = allroutes.mean(dim=0)
    
    if training:
        load = allroutes.mean(dim=0)
    else:
        indices = torch.argmax(allroutes, dim=-1)
        load = torch.zeros(experts, device=allroutes.device)
        load.scatter_add_(0, indices, torch.ones_like(indices, dtype=torch.float))
        load = load / (load.sum() + 1e-9)
        
    loss = experts * torch.sum(importance * load)
    with torch.no_grad():
        telemetry_load = (allroutes.mean(dim=0) if training else load).detach().cpu().numpy() * 100.0
    return loss, telemetry_load

