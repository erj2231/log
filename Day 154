    if torch.isnan(loss_t1) or torch.isinf(loss_t1):
        del l1, spec_chain, ph, hf, loss_t1
        print(f'!!! Scale {mdim} exploded! Skipping...')
        continue
    accumloss = accumloss + loss_t1
    print(f"Logit Mean: {loss_t1.mean().item():.4f} | Std: {loss_t1.std().item():.4f}")

    if spec_chain:
        for idx, slogits in enumerate(spec_chain):
            specloss = F.cross_entropy(slogits.reshape(-1, vocab), yb2[:, :l1.size(1)].reshape(-1))
            accumloss = accumloss + (0.5 * specloss)

    current_balance = np.zeros(experts)
    if i > 0 and routes is not None:
        clean_router_tensors = [r for r in routes if r is not None and r.numel() > 0]
        if len(clean_router_tensors) > 0:
            aux_loss, current_balance = loadbalance(clean_router_tensors, experts=4, training=True)
            z_loss = torch.logsumexp(router_probs.clamp_min(1e-9).log(), dim=-1).pow(2).mean()
            accumloss = accumloss + (0.1 * aux_loss + 0.05 * z_loss)
    
    forloss = accumloss / accum
    forloss.backward()     
    total_loss += accumloss.item() 
    del l1, spec_chain, ph, hf, loss_t1, forloss, accumloss
    timediff = (time.time() - step_start) - timenew
    
    if (i + 1) % accum == 0:
        valid_gradients = True
        for param in gpt.parameters():
            if param.grad is not None:
                if torch.isnan(param.grad).any() or torch.isinf(param.grad).any():
                    valid_gradients = False
                    break

        torch.nn.utils.clip_grad_value_(gpt.parameters(), clip_value=0.5)
        torch.nn.utils.clip_grad_norm_(gpt.parameters(), max_norm=1.0)
        if valid_gradients == True:
            optimizer.step()

        with torch.no_grad():
            if routes is not None:
                clean_router_tensors = [r for r in routes if r is not None and r.numel() > 0]
                
                if len(clean_router_tensors) > 0:
                    all_probs_tensor = torch.stack(clean_router_tensors)
                    avg_usage = all_probs_tensor.mean(dim=0)
                    if avg_usage.dim() > 1:
                        avg_usage = avg_usage.mean(dim=list(range(avg_usage.dim() - 1)))
                    elif avg_usage.dim() == 0:
                        avg_usage = avg_usage.unsqueeze(0)
                    kick_threshold = (1.0 / 8) * 0.10
                    
                    for idx, usage in enumerate(avg_usage):
                        usage_val = usage.item() if isinstance(usage, torch.Tensor) else usage
                        if usage_val < kick_threshold:
                                print(f"⚠️ Expert {idx} usage fell below threshold ({usage_val:.4f}). Perturbing weights...")
                                for name, p in gpt.named_parameters():
                                    if f'w_q.{idx}' in name or f'w_o.{idx}' in name:
                                        p.add_(torch.randn_like(p) * 0.001)
                                            
                else:
                    non_none_routes = [r for r in routes if r is not None]
                    print(f"⚠️ Warning: No valid router tensors matched criteria!")
                    if non_none_routes:
                        print(f"Actual shape of first non-None router output: {non_none_routes[0].shape}")
                        print(f"Target 'experts' count: {experts}")
                    else:
                        print("The 'routes' list is completely full of None elements.")
                if (i + 1) % accum == 0:
                    for idx, usage in enumerate(avg_usage):
                        status = 'Active'
                        if usage < (1.0 / experts) * 0.1:
                            status = "IDLE (STARVING)"
                            print('adding 0.001')
                        elif usage > (1.0 / experts) * 1.5:
                            status = 'OVERLOADED'
                        print(f"Expert {idx}: [{status}] | Load: {usage:.2%} ")

        with torch.no_grad():
            for name, param in gpt.named_parameters():
                if param.requires_grad:
                    has_grad = param.grad is not None
                    if not has_grad:
                        if i > 25:
                            print(f"!!! CRITICAL: NO GRADIENTS in {name}")
                if 'router' in name and param.grad is not None:
                    if param.grad is not None:
                        gnorm = torch.norm(param.grad).item()
                        if gnorm > 10.0:
                            print(f"!!! ROUTER UNSTABLE: {name} | Grad {gnorm:.2f} | Scaling...")
                if any(k in name for k in ['expert', 'router', 'A_log']):
                    norm = torch.norm(param).item()
                    if norm < 1e-3:
                        print(f"!!! COLLAPSE: {name}")
                        if 'router' not in name:
                            print(f"!!! COLLAPSE: {name} | Resetting parameters...")
                            param.data.normal_(mean=0.0, std=0.02)
                if 'A_log' in name and param.max() > -0.5:
                    print(f"🛡️ [LRU SHIELD] Clamping unstable memory states in {name} (Max was: {param.max().item():.4f})")
                    param.clamp_(max=-0.7)
                if torch.isnan(param).any():
                    print(f"NAN DETECTED IN: {name}")
                    param.data.fill_(0.01)

    with torch.no_grad():
        gpt.eval()
        if i <= 25:
            clean_router_tensors = [r for r in routes if r is not None and r.numel() > 0]
            usage = clean_router_tensors[-1].cpu().float().numpy() if len(clean_router_tensors) > 0 else np.zeros(experts)
        usageloss = total_loss / newi
        if i <= 25:
