            max_w_val = (L - 1) / 2
            dim_code = remaining_codes // basis[i]
            remaining_codes = remaining_codes % basis[i]
            zq_dim = dim_code.float() - max_w_val
            wq_components.append(zq_dim)
        wq_projected = torch.stack(wq_components, dim=0).sum(dim=0)
        #if is_warmup:
        #    warmup_factor = self.step_counter.float() / self.fsq_warmup_steps
        #    wq_residual = (wsliced * (1 - warmup_factor)) + (wq_projected * warmup_factor)
        #else:
        wq_residual = (wq_projected - wscaled).detach() + wscaled
        if wq_residual.requires_grad == False:
            print(wq_residual)
        lorasliced = torch.narrow(self.loraa, dim=0, start=0, length=in_f)
        res_a = x_in @ lorasliced 
        
        if self.training:
            p = 0.1
            mask = (torch.rand_like(res_a) > p).float()
            res_a = (res_a * mask) / (1 - p)
        gate = torch.sigmoid(self.gate)
        if is_warmup:
            warmup_factor = self.step_counter.float() / self.fsq_warmup_steps
            active_gate = warmup_factor * 0.5 + gate * (1 - warmup_factor)
        else:
            active_gate = gate
            
        lorabsliced = torch.narrow(self.lorab, dim=1, start=0, length=out_f)
        lora_out = (res_a @ lorabsliced) * self.scaling
        quantized_output = F.linear(x_in, wq_residual, b)
        #highway = F.linear(x_in, self.base_linear.weight, b) * 0.01
        #highway = F.linear(x_in, wsliced, b) * 0.001
        #return quantized_output + lora_out + highway
        #return (quantized_output * (1 - active_gate)) + (lora_out * active_gate)
        return quantized_output + (lora_out * active_gate)

class mrrope(nn.Module):
    def __init__(self, rdim, len=512):
        super().__init__()
        # all spectrum
        inv_freq = 1.0 / (10000 ** (torch.arange(0, rdim, 2).float() / rdim))
        # range of len
        t = torch.arange(len).float()
        # putting range onto that spectrum
        freqs = torch.outer(t, inv_freq)
        # preparing for both cos and sin
        emb = torch.cat((freqs, freqs), dim=-1)
        # registering static universe
        self.register_buffer("cos", emb.cos().view(1, len, 1, rdim))
        self.register_buffer("sin", emb.sin().view(1, len, 1, rdim))
    
    def rotatehalf(self, x, c, s):
        d_half = x.shape[-1] // 2
        x1 = x[..., :d_half]
        x2 = x[..., d_half:]
        if c.shape[-1] != d_half:
            c = torch.narrow(c, dim=-1, start=0, length=d_half)
            s = torch.narrow(s, dim=-1, start=0, length=d_half)

        # chunk much faster than interleaved
        x1, x2 = x.chunk(2, dim=-1)
        # multiplying everything in cat is much more tactical
        return torch.cat([x1 * c - x2 * s, x2 * c + x1 * s], dim=-1)
    
    def forward(self, q, k):
        B, T, H, D = q.shape
        # Ensure we don't exceed the precomputed buffer length
        # and ensure the cos/sin dimensions match the query dimension D
        cos = self.cos[:, :T, :, :D].to(q.dtype)
        sin = self.sin[:, :T, :, :D].to(q.dtype)
        
        # Because we chunk(2) in rotatehalf, we need the cos/sin 
        # for the chunked size, which is D // 2
        c_chunk, _ = cos.chunk(2, dim=-1)
        s_chunk, _ = sin.chunk(2, dim=-1)
        
        return self.rotatehalf(q, c_chunk, s_chunk), self.rotatehalf(k, c_chunk, s_chunk)

class newmla(nn.Module):
    def __init__(self, emb, n_heads=4, latent_dim=64, rope_dim=32):
        super().__init__()
        self.n_heads = n_heads
        # dim on 1 head
        self.head_dim = emb // n_heads
        self.rope_dim = rope_dim
        # norm before up
        self.norm = rms(emb)
        # Wrapping projections in fsqlora to enable LoRA adapters + Quantized base
        self.kv_down = fsqlora(nn.Linear(emb, latent_dim, bias=False))
        self.kv_up = fsqlora(nn.Linear(latent_dim, n_heads * (self.head_dim + rope_dim + self.head_dim), bias=False))
        # better to init one big then split
        self.q_proj = fsqlora(nn.Linear(emb, n_heads * (self.head_dim + rope_dim), bias=False))
        self.out_proj = nn.Linear(n_heads * self.head_dim, emb, bias=False)
        # 0.1 as i want normal distribution in kvdown
        #nn.init.xavier_uniform_(self.kv_down.base_linear.weight, gain=1.0)
        #nn.init.xavier_uniform_(self.kv_up.base_linear.weight, gain=0.1)
        #nn.init.xavier_uniform_(self.q_proj.base_linear.weight, gain=0.1)
        nn.init.xavier_uniform_(self.out_proj.weight, gain=1.0)
        #with torch.no_grad():
            #nn.init.normal_(self.kv_down.lorab, mean=0.0, std=1e-4)
            #nn.init.normal_(self.kv_up.lorab, mean=0.0, std=1e-4)
            #nn.init.normal_(self.q_proj.lorab, mean=0.0, std=1e-4)
            #nn.init.kaiming_normal_(self.kv_down.lorab, a=math.sqrt(5))
            #nn.init.kaiming_normal_(self.kv_up.lorab, a=math.sqrt(5))
            #nn.init.kaiming_normal_(self.q_proj.lorab, a=math.sqrt(5))

    def forward(self, x, rope_obj, active4, tau):
        # x: [B, T, emb]
        current_latent = max(32, active4 // 4)
        B, T, _ = x.shape
        #xsliced = x[..., :active4]
        xsliced = torch.narrow(x, dim=-1, start=0, length=active4)
        max_allowed_latent = self.kv_down.base_linear.weight.shape[0]
        current_latent = min(current_latent, max_allowed_latent)

        # quantize activations (leave FSQ behavior intact)
        x_q = self.norm(xsliced, active4)
        #x_q = x_q[..., :active4]
        x_q = torch.narrow(x_q, dim=-1, start=0, length=active4)
        x_q = x_q.flatten(0, -2)
        x_q = self.kv_down.quantize_val(x_q)

        # latent kv
        kv_latent = self.kv_down(x_q, tau=tau, out_slice=current_latent, in_slice=active4)
        kv_latent = kv_latent.flatten(0, -2)
        kv_latent = self.kv_down.quantize_val(kv_latent)
        
        total_needed_per_head = self.head_dim + self.rope_dim + self.head_dim # 224
        total_width = self.n_heads * total_needed_per_head

        # project to per-head K/V
        kv = self.kv_up(kv_latent, tau=tau, out_slice=total_width, in_slice=current_latent)
        kv = kv.view(B, T, self.n_heads, total_needed_per_head)
        k_content, k_pe, v = torch.split(kv, [self.head_dim, self.rope_dim, self.head_dim], dim=-1)

        total_q_width = self.n_heads * (self.head_dim + self.rope_dim)
        # project Q from x (not from kv)
        q = self.q_proj(x_q, tau=tau, out_slice=total_q_width, in_slice=active4)
        q = q.view(B, T, self.n_heads, -1)
        q_content, q_pe = torch.split(q, [self.head_dim, self.rope_dim], dim=-1)

        # RoPE on positional parts
        q_pe, k_pe = rope_obj(q_pe, k_pe)

        # combine content+pos
        q = torch.cat([q_content, q_pe], dim=-1).transpose(1, 2)  
        # [B, H, T, head_dim+rope_dim]
        k = torch.cat([k_content, k_pe], dim=-1).transpose(1, 2)
        v = v.transpose(1, 2)  # [B, H, T, head_dim]

        current_head_dim = q_content.size(-1)
        dynamic_scale = 1.0 / math.sqrt(current_head_dim + self.rope_dim)
        q_scaled = q * dynamic_scale

        # attention
        out = F.scaled_dot_product_attention(q_scaled, k, v, is_causal=True, scale=1.0)
        out = out.transpose(1, 2).reshape(B, T, self.n_heads * self.head_dim)

        # project back to model dim (slice to active4)
        #outprojsliced = self.out_proj.weight[:active4]
        #outprojsliced = torch.narrow(outprojsliced, dim=1, start=0, length=self.n_heads * current_head_dim)
        #out = F.linear(out, outprojsliced, None)
        out = F.linear(out, self.out_proj.weight, None)
        out = torch.narrow(out, dim=-1, start=0, length=active4)
        return x + out

class moe(nn.Module):
    def __init__(self, emb, experts, latent_dim=None):
        super().__init__()
        self.experts = experts
        self.kv_dim = latent_dim or (emb // 4)
        
        self.w_q = nn.ModuleList([
            fsqlora(nn.Linear(emb, self.kv_dim, bias=False))
            for _ in range(experts)
        ])
        self.w_o = nn.ModuleList([
            fsqlora(nn.Linear(self.kv_dim, emb, bias=False))
            for _ in range(experts)
        ])

        self.balance_temp = nn.Parameter(torch.tensor(1.0))
        self.gate = nn.Parameter(torch.tensor(1.0))
        self.norm = nn.ModuleList([rms(self.kv_dim) for _ in range(experts)])
        #with torch.no_grad():
            #for e in range(experts):
                #nn.init.kaiming_normal_(self.w_q[e].lorab, a=math.sqrt(5))
                #nn.init.kaiming_normal_(self.w_o[e].lorab, a=math.sqrt(5))
                #nn.init.xavier_uniform_(self.w_q[e].base_linear.weight, gain=0.05)
                #nn.init.xavier_uniform_(self.w_o[e].base_linear.weight, gain=0.01)
                #nn.init.normal_(self.w_q[e].lorab, mean=0.0, std=1e-4)
                #nn.init.normal_(self.w_o[e].lorab, mean=0.0, std=1e-4)

    def forward(self, x, route, active4=None, tau=1.0, step=1, training=False):
        #xsliced = x[..., :active4]
        xsliced = torch.narrow(x, dim=-1, start=0, length=active4)
        B, T, C = xsliced.shape
        x_flat = xsliced.view(-1, C) 
        kv_slice = max(32, active4 // 4)
        
        logits = route.view(-1, route.shape[-1])
        if route.dim() == 3:
            logits = F.pad(logits, (0, self.experts - logits.shape[-1]))
            
        progress = min(1.0, step / 80000)
        exploration = 0.2 * (1.0 - progress)
        #route = F.gumbel_softmax(gate_scores + self.branch.bias, tau=tau, hard=False)
        noise = -torch.rand_like(logits).exponential_()
        gumbels = -torch.clamp(noise, min=1e-7, max=10.0).log()
        logits_stable = (logits / (tau + 1e-8)) + (gumbels * exploration)

        chosen_experts = torch.argmax(logits_stable, dim=-1)
        logits_stable = logits_stable / (C ** 0.5)
        router_logits = torch.clamp(logits_stable, min=-5.0, max=5.0)
        gate_scores = F.softmax(router_logits / (F.softplus(self.balance_temp) + 1e-6), dim=-1)
        gate_scores = gate_scores + 1e-3
        gate_scores = gate_scores / gate_scores.sum(dim=-1, keepdim=True)
        hardgate = torch.zeros_like(gate_scores).scatter_(-1, chosen_experts.unsqueeze(-1), 1.0)
        gates = hardgate - gate_scores.detach() + gate_scores
        
        final_output = x_flat * self.gate
        for e in range(self.experts):
            expert_gates = gates[:, e:e+1]
            #total_rows = expert_gates.shape[0]
            #calculated_k = int(0.20 * total_rows)
            #k_capacity = max(1, calculated_k)
            k_capacity = 4
            topk_vals, _ = torch.topk(expert_gates.squeeze(-1), k=k_capacity)
            threshold = topk_vals[-1]
            token_selection_mask = (expert_gates.squeeze(-1) >= threshold)
            print(expert_gates)
            print(token_selection_mask)
            
            # 2. Straight-Through Estimator Math
            soft_mask = expert_gates / (expert_gates.detach() + 1e-8)
            hard_mask = token_selection_mask.float().unsqueeze(-1)
            ste_capacity_mask = hard_mask - soft_mask.detach() + soft_mask
            
            # 3. Gather active row positions
            indices = torch.nonzero(token_selection_mask).squeeze(1)
            
            # 🟢 FIX: Create an explicit tracking mask vector for valid tokens
            # 1.0 for true active indices, 0.0 for the trailing fallback buffer slot
            valid_indicators = torch.ones_like(indices, dtype=torch.float32)
            fallback_indicator = torch.zeros(1, dtype=torch.float32, device=x_flat.device)
            active_weights_mask = torch.cat([valid_indicators, fallback_indicator], dim=0)
            
            # 🟢 FIX: Always append index 0 to the tail. safe_indices size is ALWAYS exactly indices.numel() + 1
            fallback_index = torch.zeros(1, dtype=torch.long, device=x_flat.device)
            safe_indices = torch.cat([indices, fallback_index], dim=0)
            
            # 4. COMPUTE: Uniform forward pass (No dynamic truncations or SymInt max calls!)
            x_hot = torch.index_select(x_flat, 0, safe_indices)
            
            x_hot = x_hot.flatten(0, -2)
            x_q = self.w_q[e].quantize_val(x_hot)
            #x_qsliced = x_q[..., :active4]
            x_qsliced = torch.narrow(x_q, dim=-1, start=0, length=active4)
            wq_q = self.w_q[e](x_qsliced, tau=tau, out_slice=kv_slice, in_slice=active4) 
            
            wqnorm = self.norm[e](wq_q, active4=kv_slice)
            #wqnorm = wqnorm[..., :active4]
            wqnorm = torch.narrow(wqnorm, dim=-1, start=0, length=active4)
            mid = F.silu(wqnorm)
            wo_q = self.w_o[e](mid, tau=tau, out_slice=active4, in_slice=kv_slice)

            # Gather tracking weights matching our safe layout 
            #sliced_mask_rows = torch.index_select(ste_capacity_mask, 0, safe_indices)
            #slice_weights = sliced_mask_rows[:, 0:1]
            #total_row_weight = slice_weights * active_weights_mask.unsqueeze(-1)
            #wo_q = wo_q * total_row_weight
            #weighted_wo_q = wo_q * (ste_capacity_mask - ste_capacity_mask.detach() + 1.0)

            #ste_grad_scale = sliced_mask_rows - sliced_mask_rows.detach() + 1.0
            #wo_q = wo_q * ste_grad_scale
            total_row_weight = active_weights_mask.unsqueeze(-1)
            hard_mask = (expert_gates >= threshold).float()
            ste_capacity_mask = hard_mask - gate_scores.detach() + gate_scores
            current_expert_mask = ste_capacity_mask.gather(0, safe_indices.unsqueeze(-1))
            expert_mask_slice = current_expert_mask[:, e:e+1] 
            if expert_mask_slice.numel() == 0: continue
            masked_wo = wo_q * expert_mask_slice
        
            global_contribution = torch.zeros_like(x_flat)
            
            # We align indices with active rows via an index_add operation
            # We mask out the fallback index item using our active_weights_mask
            masked_contribution = masked_wo * total_row_weight
            
            global_contribution.index_add_(0, safe_indices, masked_contribution)
            final_output = final_output + global_contribution

        output_reshaped = final_output.view(B, T, active4)
        #padded_output = F.pad(output_reshaped, (0, x.shape[-1] - active4))
        pad_len = int(x.shape[-1] - int(active4))

        # Wrap the padding operation to handle concrete value guards
        padded_output = F.pad(output_reshaped, (0, pad_len))
        token_entropy = -torch.sum(gate_scores * torch.log(gate_scores + 1e-10), dim=-1).mean()
        
        # 🟢 This return statement feeds the unpack operator upstream!
        padded = x + padded_output
        return pad(padded), pad(token_entropy)

class lnn(nn.Module):
    def __init__(self, emb):
        super().__init__()
        self.dt = fsqlora(nn.Linear(emb * 2, emb))
        # -2 is a good gating
        #nn.init.constant_(self.dt.base_linear.bias, -2.0)
        #with torch.no_grad():
            #nn.init.normal_(self.dt.lorab, mean=0.0, std=0.1)

    def forward(self, h, combined_context, tau=1.0, active4=None):
        #h = h[..., :active4]
        h = torch.narrow(h, dim=-1, start=0, length=active4)
        #combined_context = combined_context[..., :active4]
        combined_context = torch.narrow(combined_context, dim=-1, start=0, length=active4)
        combined = torch.cat([combined_context, h], dim=-1)
        # Get adapted weight with specific Matryoshka slicing
        # active4*2 for the concatenated input, active4 for output
        wq_dt = self.dt(combined, tau=tau, out_slice=active4, in_slice=active4*2)
        dt = torch.sigmoid(wq_dt)
        # [384] + ([384] - [384]) * [384] -> [384]
        # tanh used for bigger spectrum
        lln = h + (-h + torch.tanh(combined_context)) * dt
        return pad(lln)

class swigluznn(nn.Module):
    def __init__(self, emb):
        super().__init__()
        hidden_dim = int(8/3 * emb)
        # better to init one and split then two
        self.w_combined = fsqlora(nn.Linear(emb, hidden_dim * 2, bias=False))
        self.w_down = fsqlora(nn.Linear(hidden_dim, emb, bias=False))
            #self.w_combined.base_linear.weight[:hidden_dim] *= 0.1
            # 1.0 for up
            #nn.init.xavier_uniform_(self.w_down.base_linear.weight, gain=0.02)

    def forward(self, x, active4=None, tau=1.0):
        active_hidden = (8 * active4) // 3
        target_out = active_hidden * 2
        #xsliced = x[..., :active4]
        xsliced = torch.narrow(x, dim=-1, start=0, length=active4)
        combined = self.w_combined(xsliced, tau=tau, out_slice=target_out, in_slice=active4)
        #if combined.shape[-1] < 2:
        #    gate = up = combined
        #else:
        #    gate, up = torch.chunk(combined, 2, dim=-1)
        #current_width = combined.size(-1)
        #half_width = torch.clamp(current_width // 2, min=1)
        #half_width = max(1, current_width // 2)
        #gate, up = torch.split(combined, [half_width, current_width - half_width], dim=-1)
        #half_width = current_width // 2
        #gate = torch.narrow(combined, dim=-1, start=0, length=half_width)
        #up   = torch.narrow(combined, dim=-1, start=half_width, length=half_width)

        new_shape = list(combined.shape[:-1]) + [2, active_hidden]
        reshaped = combined.view(new_shape)
        gate, up = torch.unbind(reshaped, dim=-2)
        hff = F.silu(gate) * up    
        wq_down = self.w_down(hff, tau=tau, out_slice=active4, in_slice=active_hidden)
        # [B, T, 682] @ [682, 256] -> [B, T, 256]
        final = x + wq_down
        return pad(final)

