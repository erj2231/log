class rms(nn.Module):
    def __init__(self, dim, eps=1e-4):
        super().__init__()
        self.eps = eps
        self.weight = nn.Parameter(torch.ones(dim))
    
    def forward(self, x, active4=512):
        #x = x[..., :active4]
        x = torch.narrow(x, dim=-1, start=0, length=active4)
        normx = x * torch.rsqrt(x.pow(2).mean(-1, keepdim=True) + self.eps)
        if active4 is None:
            active4 = x.shape[-1]
        wsliced = self.weight[:active4]
        final = normx * wsliced
        return pad(final)

class rmsfordstate(nn.Module):
    def __init__(self, dim, eps=1e-4):
        super().__init__()
        self.eps = eps
        self.weight = nn.Parameter(torch.ones(dim))
    
    def forward(self, x, active4=512):
        #x = x[..., :active4]
        x = torch.narrow(x, dim=2, start=0, length=active4)
        normx = x * torch.rsqrt(x.pow(2).mean(-1, keepdim=True) + self.eps)
        if active4 is None:
            active4 = x.shape[-1]
        wsliced = self.weight[:active4]
        wsliced = wsliced.view(1, 1, -1, 1)
        final = normx * wsliced
        return pad(final)

