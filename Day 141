        #padding_needed = torch.clamp(kernel_size - T, min=0)
        #padding_needed = max(0, kernel_size - T)
        #zero_padding = torch.zeros(pad_shape, dtype=x_sliced.dtype, device=x_sliced.device)
        x_conv_out = F.conv1d(
            x_conv_in,
            weight=w_sliced,
            bias=b_sliced,
            stride=1,
            padding=3,
            groups=safe_active4 # Groups matches active channel size perfectly
        )
        #x_padded = F.pad(x_input_padded.transpose(1, 2), (3, 3), mode='constant', value=0.0) # Shape: [B, safe_active4, T + 6]
        #x_windows = x_padded.unfold(dimension=-1, size=4, step=1)
        #x_windows = torch.narrow(x_windows, dim=2, start=0, length=T) 
        #w_expanded = conv1dsliced.unsqueeze(0)
        #x_conv = torch.sum(x_windows * w_expanded, dim=-1)
        #x_conv = x_conv + convbiassliced.view(1, -1, 1)
        #x_conv = x_conv.transpose(1, 2)

        #conv_sequence_len = x_conv.size(1)
        #target_T = min(T, conv_sequence_len)
        #x_convsliced = torch.narrow(x_conv, dim=1, start=0, length=target_T)
        #x_convsliced = torch.narrow(x_convsliced, dim=-1, start=0, length=active4)
        x_conv = x_conv_out.transpose(1, 2)
        x_active = F.silu(torch.narrow(x_conv, dim=1, start=0, length=T)) 
        total_db_dim = self.dt_rank + self.d_state + self.d_state
        x_db = self.x_proj(x_active, tau=tau, out_slice=total_db_dim, in_slice=active4) 
        dt_raw, b_vals, c_vals = torch.split(x_db, [self.dt_rank, self.d_state, self.d_state], dim=-1)
        #dt_active = torch.narrow(dt_raw, dim=-1, start=0, length=active4) 
        dtlinear = self.dt_proj(dt_raw, tau=tau, out_slice=active4, in_slice=self.dt_rank)
        dt = F.softplus(dtlinear * 0.1)
        dt = torch.clamp(dt, min=1e-4, max=5.0)
        alogsliced = self.A_log[:active4]
        a_log_base = alogsliced.float()
        if training:
            a_noise = (torch.rand_like(a_log_base) - 0.5) * (tau * 0.02)
            a_log_base = a_log_base + a_noise
        a_log_sliced = torch.clamp(a_log_base, min=-6.0, max=-0.5)
        A = -torch.exp(a_log_sliced)
        if training:
            log_decay = dt * A.view(1, 1, -1) 
            cum_decay = torch.cumsum(log_decay, dim=1)
            cum_decay = torch.clamp(cum_decay, min=-50.0, max=50.0)
            
            dt_active = torch.narrow(dt, dim=1, start=0, length=T)
            #dt_active = dt_active[..., :active4]
            dt_active = torch.narrow(dt_active, dim=-1, start=0, length=active4)
            b_active = torch.narrow(b_vals, dim=-1, start=0, length=self.d_state)
            c_active = torch.narrow(c_vals, dim=-1, start=0, length=self.d_state)

            term = (x_active * dt_active).unsqueeze(-1) * b_active.unsqueeze(-2)
            max_decay = cum_decay.max(dim=1, keepdim=True)[0]
            u_discounted = term * torch.exp(-(cum_decay - max_decay)).unsqueeze(-1)
            history = torch.cumsum(u_discounted, dim=1)
            decay = torch.exp(cum_decay - max_decay).unsqueeze(-1)
            state = history * decay

            if nextstate is not None:
                newstate = nextstate.unsqueeze(1) * torch.exp(cum_decay).unsqueeze(-1)
                combinedstate = state + newstate
            else:
                combinedstate = state
            
            laststate = combinedstate[:, -1].detach()

            combinedstate = self.state_norm(combinedstate, active4)
            combinedstate = combinedstate[:, :, :active4, :self.d_state]
            #print(combinedstate.shape)
            #print(c_active.shape)
            y = (combinedstate * (c_active.unsqueeze(2))).sum(dim=-1)
            ysliced = torch.narrow(y, dim=1, start=0, length=T)
            #ysliced = ysliced[..., :active4]
            ysliced = torch.narrow(ysliced, dim=-1, start=0, length=active4)
            return x_sliced + ysliced * self.changeable, laststate
        else:
            # 1. ALWAYS read target_width from the incoming sliced data stream first
            target_width = x_active.shape[-1] 
            
            # 2. State container always stays allocated at full maximum size (self.emb)!
            if nextstate is None:
                state = torch.zeros(B_size, self.emb, self.d_state, device=x.device, dtype=x.dtype)
            else:
                state = nextstate  # Already guaranteed to be shape [B, self.emb, d_state]

            #y_outlist = []
            y_outlist = torch.zeros(B_size, T, target_width, device=x.device, dtype=x.dtype)
            for t in range(T): 
                dtsliced = dt[:, t, :target_width].unsqueeze(-1)      # Shape: [B, target_width, 1]
                bsliced = b_vals[:, t, :self.d_state].unsqueeze(-1)   # Shape: [B, d_state, 1]
                csliced = c_vals[:, t, :self.d_state].unsqueeze(-1)   # Shape: [B, d_state, 1]
                xsliced = x_active[:, t, :target_width].unsqueeze(-1)
                
                if A.shape[0] != target_width:
                    if target_width % A.shape[0] == 0:
                        A_aligned = A.repeat(target_width // A.shape[0])
                    else:
                        A_aligned = A.repeat((target_width // A.shape[0]) + 1)
                        A_aligned = torch.narrow(A_aligned, dim=0, start=0, length=target_width)
                else:
                    A_aligned = A

                decay = torch.exp(dtsliced * A_aligned.view(1, -1, 1))
                decay = torch.clamp(decay, min=0.0, max=0.99)

                # Outer-product calculation for the current active slice footprint
                input_update = (xsliced * dtsliced) @ bsliced.transpose(-1, -2) # Shape: [B, target_width, d_state]
                
                # 🟢 APPLY RECURRENCE SEPARATELY FOR THE ACTIVE WORKSPACE SLICE
                # We extract the active portion from full memory, step it, and write it back!
                active_state = state[:, :target_width, :]
                active_state = active_state * decay + input_update
                
                # Save the updated slice back into full state memory seamlessly
                #active_state = torch.narrow(state, dim=1, start=0, length=target_width)
                state[:, :target_width, :] = active_state

                squared_state = torch.pow(active_state, 2)
                state_mean = torch.mean(squared_state, dim=-1, keepdim=True)
                
                # Apply stable scale factor safely inside the reciprocal root
                state_rms = torch.rsqrt(state_mean * 2.0 + 1e-5)
                
                #state_rms = torch.rsqrt(torch.mean(active_state * math.sqrt(2), dim=-1, keepdim=True) + 1e-4)
                normstate = active_state * state_rms

                # Project hidden state back to vector space via c_vals channel weights
                y_t = torch.matmul(normstate, csliced).squeeze(-1) # Shape: [B, target_width]
                #y_outlist.append(y_t)
                y_outlist[:, t, :] = y_t
                
            #y_out = torch.stack(y_outlist, dim=1)
            final = x_sliced + 0.01 * y_t * self.changeable
            return pad(final), pad(state)

class heads(nn.Module):
    def __init__(self, emb, vocab, spec_count):
        super().__init__()
        self.embed = nn.Embedding(vocab, emb)
        self.spec_count = spec_count
        # Norms
        self.norm_f = rms(emb)
        self.norm_mtp = rms(emb)
        # Wrapped Projections
        self.gate = fsqlora(nn.Linear(emb, emb))
        self.pred_state = fsqlora(nn.Linear(emb, emb))
        # Multi-Token Prediction Heads
        self.spec_heads = nn.ModuleList([
            fsqlora(nn.Linear(emb, emb)) for _ in range(spec_count)
        ])
        # Inits
        #nn.init.normal_(self.embed.weight, mean=0.0, std=0.02)
        #nn.init.xavier_uniform_(self.gate.base_linear.weight, gain=1.0)
        nn.init.constant_(self.gate.base_linear.bias, -2.0)
        #for h in self.spec_heads:
            #nn.init.xavier_uniform_(h.base_linear.weight, gain=0.1)
            #nn.init.normal_(h.lorab, mean=0.0, std=0.1)
        #nn.init.normal_(self.pred_state.lorab, mean=0.0, std=0.1)
        #nn.init.normal_(self.gate.lorab, mean=0.0, std=0.1)

    def opo_linear(self, x, weight, chunks=4):
        # [V, E] chunked for memory efficiency
        vocab_chunks = torch.chunk(weight, chunks, dim=0)
        logits = [F.linear(x, w_c) for w_c in vocab_chunks]
        return (torch.cat(logits, dim=-1))
    
    def forward(self, h_final, i4=None, active4=None, tau=1.0, grid_levels=[8, 5, 5]):
        #hsliced = h_final[..., :active4]
        hsliced = torch.narrow(h_final, dim=-1, start=0, length=active4)
        #i4sliced = i4[..., :active4]
        i4sliced = torch.narrow(i4, dim=-1, start=0, length=active4)
        hnorm = self.norm_f(hsliced, active4)
        i4norm = self.norm_f(i4sliced, active4)
        #hnormsliced = hnorm[..., :active4]        
        hnormsliced = torch.narrow(hnorm, dim=-1, start=0, length=active4)
        #i4normsliced = i4norm[..., :active4]        
        i4normsliced = torch.narrow(i4norm, dim=-1, start=0, length=active4)
        hnormsliced = hnormsliced.flatten(0, -2)
        h_norm = self.gate.quantize_val(hnormsliced)
        i4normsliced = i4normsliced.flatten(0, -2)
        i4_norm = self.gate.quantize_val(i4normsliced)
        # 1. Gate Logic
        wq_gate = self.gate(h_norm, tau=tau, out_slice=active4, in_slice=active4)
        g = torch.sigmoid(wq_gate)
        # head
        ph = self.pred_state(i4_norm, tau=tau, out_slice=active4, in_slice=active4)
        # MTP State
        curr_mtp_state = self.norm_mtp(i4_norm + (ph * g), active4)
        #curr_mtp_state = curr_mtp_state[..., :active4]\
        curr_mtp_state = torch.narrow(curr_mtp_state, dim=-1, start=0, length=active4)
        curr_mtp_state = curr_mtp_state.flatten(0, -2)
        curr_mtp_state = self.gate.quantize_val(curr_mtp_state)
        # Classifier (Weight Tying)
        #embedsliced = self.embed.weight[..., :active4]
        embedsliced = torch.narrow(self.embed.weight, dim=-1, start=0, length=active4)
        logits = self.opo_linear(curr_mtp_state, embedsliced)
        logits = torch.clamp(logits, -30.0, 30.0)
        # 3. MTP Chain
        mtp_logits_chain = []
        for spec_layer in self.spec_heads:
            wq_spec = spec_layer(curr_mtp_state, out_slice=active4, in_slice=active4)
            next_state = torch.tanh(wq_spec)
            curr_mtp_state = self.norm_mtp(next_state, active4)
            #curr_mtp_state = curr_mtp_state[..., :active4]
            curr_mtp_state = torch.narrow(curr_mtp_state, dim=-1, start=0, length=active4)
            curr_mtp_state = curr_mtp_state.flatten(0, -2)
            curr_mtp_state = self.gate.quantize_val(curr_mtp_state)
            step_logits = self.opo_linear(curr_mtp_state, embedsliced)
            mtp_logits_chain.append(torch.clamp(step_logits, -30.0, 30.0))
        return pad(logits), pad(mtp_logits_chain), pad(ph), pad(h_norm)

class layer(nn.Module):
    def __init__(self, i, emb, experts):
        super().__init__()
        self.i = i
        self.lnn = lnn(emb)
        self.norm1 = rms(emb)
        self.norm2 = rms(emb)
        self.rope = mrrope(rdim=32)
        self.smallparam = nn.Parameter(torch.ones(emb) * 1.0)

        if i != 3 and i != 7:
            self.is_expert = True
            self.branch = moe(emb, experts)
            self.router = nn.Linear(emb, experts, bias=False)
            with torch.no_grad():
                nn.init.orthogonal_(self.router.weight, gain=1.0)
                #nn.init.trunc_normal_(self.router.weight, std=0.02)
        else:
            self.is_expert = False
            self.branch = swigluznn(emb)
            self.router = None

        if i != 3 and i != 7:
            self.is_global = True
            self.mla = newmla(emb)
        else:
            self.is_global = False
            self.lrussd = lru(emb)

    def forward(self, h, lrustate, tau, step, training=False, active4=None):
        #resscale = (128.0 / active4.float()) * torch.sqrt(2)
        resscale = (256.0 / active4) * math.sqrt(2)
        #hsliced = h[..., :active4]
        hsliced = torch.narrow(h, dim=-1, start=0, length=active4)
        #if active4 == 384:
        #    hsliced = torch.clamp(hsliced, -4.0, 4.0)
        #elif active4 == 256:
        #    hsliced = torch.clamp(hsliced, -6.0, 6.0)
        #elif active4 == 128:
        #    hsliced = torch.clamp(hsliced, -8.0, 8.0)
        #else:
        #    hsliced = torch.clamp(hsliced, -10.0, 10.0)

        # 1. Context Branch
        if self.is_global:
            h_context = self.mla(hsliced, self.rope, active4, tau)
            next_state = None
        else:
            h_context, next_state = self.lrussd(hsliced, tau=tau, nextstate=lrustate, training=training, active4=active4)
        #h_context = h_context[..., :active4]
        h_context = torch.narrow(h_context, dim=-1, start=0, length=active4)
        h_context = 6.0 * torch.tanh(h_context / 6.0)
        h_context = hsliced + (h_context * resscale)
        h_context = self.norm1(h_context, active4)
        h_context = h_context[..., :active4]
        #h_context = torch.narrow(h_context, dim=-1, start=0, length=active4)

        if self.is_expert:
            #routersliced = torch.narrow(self.router.weight, dim=1, start=0, length=active4)
            routersliced = self.router.weight[:4, :active4]
            #router_logits = F.linear(h_context, routersliced)
            router_logits = torch.matmul(h_context, routersliced.t())
            actual_experts = routersliced.size(0)
            routerlogitsspec = torch.narrow(router_logits, dim=-1, start=0, length=actual_experts)
            router_logits = routerlogitsspec / 4.0
            router_logits = torch.clamp(router_logits, -8.0, 8.0)
            combined_context, route = self.branch(h_context, router_logits, active4, tau, step=step, training=training)
        else:
            combined_context = self.branch(h_context, active4, tau)
            route = None
        #combined_context = combined_context[..., :active4]
        combined_context = torch.narrow(combined_context, dim=-1, start=0, length=active4)
        combined_context = torch.clamp(combined_context, -6.0, 6.0)
        hffn = h_context + (combined_context * resscale)
        hffn = self.norm2(hffn, active4)

        # 3. Liquid Fusion
        h_liquid = self.lnn(h_context, hffn, tau, active4)
        #h_liquid = h_liquid[..., :active4]
        h_liquid = torch.narrow(h_liquid, dim=-1, start=0, length=active4)
        smallsliced = self.smallparam[:active4]
        l1 = h_context + (h_liquid * smallsliced)
        return pad(l1), pad(next_state), route

class model(nn.Module):
    def __init__(self, vocab, emb, n_layers, n_experts, spec_count=2):
        super().__init__()
        self.vocab = vocab
        self.emb = emb
        self.embed = nn.Embedding(vocab, emb)
        self.layers = nn.ModuleList([layer(lidx, emb, n_experts) for lidx in range(n_layers)])
        self.heads = heads(emb, vocab, spec_count)
        #nn.init.normal_(self.embed.weight, std=0.02)
        self.mtpmix = nn.Parameter(torch.ones(emb) * 1.0)
        self.gate = nn.ParameterList([nn.Parameter(torch.ones(1) * 0.0) for _ in range(n_layers - 1)])
        self.get_conf = nn.Parameter(torch.randn(emb) * 0.0)
        
    #def pack(self, h, states, mask):
    #    B, T, C = h.shape
    #    hot_indices = torch.nonzero(mask.view(-1)).squeeze(1)
    #    h_hot = h.view(-1, C)[hot_indices]
    #    states_hot = None
    #    if states is not None and states[0] is not None:
    #        states_hot = [s.view(-1, states[0].shape[-1])[hot_indices] for s in states]
    #    return h_hot, states_hot, hot_indices

    def forward(self, x, lru_states=None, tau=1.0, active4=512, active2=512, kratio=1.0, step=1, training=False):
        #active4 = active4.item()
        #active4 = torch._dynamo.assume_constant_result(active4.item())
        h = self.embed(x) * active2
        active4 = int(active4)
        #hsliced = h[..., :active4]
        hsliced = torch.narrow(h, dim=-1, start=0, length=active4)
        B, T, C = h.shape
        if lru_states is None:
            lru_states = [None] * len(self.layers)

        routes = []
        new_states = []
        if training and self.layers[0].training:
            h_new, ns, r = checkpoint(
                self.layers[0], hsliced, lru_states[0], tau, step, training, active4,
                use_reentrant=False 
            )
        else:
            h_new, ns, r = self.layers[0](hsliced, lru_states[0], tau, step, training=training, active4=active4)
        #h_new = h_new[..., :active4]
        h_new = torch.narrow(h_new, dim=-1, start=0, length=active4)
        i4 = h.clone()
        new_states.append(ns)
        if r is not None:
            routes.append(r)
        h = h_new

        for lidx in range(1, len(self.layers)):
            gateval = torch.sigmoid(self.gate[lidx-1])
            getconfsliced = self.get_conf[:active4]
            #print(getconfsliced.shape)
            #logits = torch.matmul(h, getconfsliced)
            scores = torch.sigmoid(getconfsliced) @ h.transpose(1, 2)
            conf = scores.unsqueeze(-1)
            if training == True:
                is_sparse_mask = (kratio < 1.0)
                #is_sparse = bool((kratio < 1.0).item())
                #if is_sparse:
                #logits = torch.matmul(h, getconfsliced)
                #scores = torch.sigmoid(logits)
                calculated_k = (B * T * kratio).to(torch.int32)
                topk = torch.clamp(calculated_k, min=2)
                scoresflat = scores.view(-1)
                torch._check((topk > 0).item())
                _, indices = torch.topk(scoresflat, topk)
                #_, indices = torch.topk(scoresflat, topk)
                tmpmask = torch.zeros_like(scoresflat)
                tmpmask = tmpmask.scatter(0, indices, 1.0)
                sparse_mask = tmpmask.view_as(conf)
                #active_mask = torch.where(is_sparse_mask, sparse_mask, torch.ones_like(sparse_mask))
                ones_canvas = torch.ones_like(conf)
                active_mask = torch.where(is_sparse_mask, sparse_mask, ones_canvas)
                masked_h = h * active_mask
                torch._check(masked_h.shape[0] > 0)
                torch._check(masked_h.shape[1] > 0)
                #hhot, _, _ = self.pack(h, [lru_states[lidx]], tmpmask)
                if self.layers[lidx].training:
                    h_new, ns, r = checkpoint(
                        self.layers[lidx], masked_h, lru_states[lidx], tau, step, training, active4,
                        use_reentrant=False
                    )
                else:
                    h_new, ns, r = self.layers[lidx](masked_h, lru_states[lidx], tau, step, training, active4)
                #_new = h_new[..., :active4]
                h_new = torch.narrow(h_new, dim=-1, start=0, length=active4)
                #h_new = h.view(-1, C).clone()
                #h_new.scatter(0, indices.unsqueeze(1).expand(-1, C), hnewhot)
                #h_new = h_new.view(B, T, C)
                h_update_sparse = (h_new - h) * conf * gateval * active_mask
                h_update_dense = (h_new - h) * gateval
                h = h + torch.where(is_sparse_mask, h_update_sparse, h_update_dense)
                new_states.append(ns)
                if r is not None:
                    routes.append(r)
                #else:
                    #if lidx < len(self.layers) - 1:
                        #h_new, ns, r = checkpoint(self.layers[lidx], h, lru_states[lidx], tau, training=training, active4=active4, use_reentrant=False)
                    #else:
                    #h_new, ns, r = self.layers[lidx](h, lru_states[lidx], tau, step, training, active4)
                    #h = h + (h_new - h) * gateval
            else:                
                with torch.no_grad():
                    threshold = 0.82 + 0.03 * (lidx + 1)
                    layer_mask = (conf < threshold).float()
                h_new, ns, r = self.layers[lidx](h, lru_states[lidx], tau, step, training, active4)
                #h_new = h_new[..., :active4]
                h_new = torch.narrow(h_new, dim=-1, start=0, length=active4)
                if layer_mask.dim() < h.dim():
                    layer_mask = layer_mask.view(h.size(0), 1, 1)
                h = h + (h_new - h) * layer_mask * gateval
                new_states.append(ns)
                if r is not None:
                    routes.append(r)
                if layer_mask.sum() < 0:
                    print(f"Early exit triggered at Layer {lidx}.")
                    break
            new_states.append(ns)
            if r is not None:
                routes.append(r)
        while len(new_states) < len(self.layers):
            missing_idx = len(new_states)
            new_states.append(lru_states[missing_idx])

        mtpmixsliced = self.mtpmix[:active4]

        # Force all tensors to share the exact same active feature width dimension
        #h_sliced = h[..., :active4]
        h_sliced = torch.narrow(h, dim=-1, start=0, length=active4)
        #i4_sliced = i4[..., :active4]
        i4_sliced = torch.narrow(i4, dim=-1, start=0, length=active4)

        # Compute the tanh element-wise mix securely
        h_combined = h_sliced + (i4_sliced * torch.tanh(mtpmixsliced))

        # If your downstream modules (like self.heads) require the full un-sliced canvas width, 
        # pad the result back out to match your base embedding space layer dimension:
        pad_len = int(h.shape[-1] - int(active4))
        h = F.pad(h_combined, (0, pad_len))

        #mtpmixsliced = torch.narrow(self.mtpmix, dim=0, start=0, length=active4)
        #h = h + (i4 * torch.tanh(mtpmixsliced))
        l1, spec, ph, h_final = self.heads(h, i4, active4, tau)                
        return l1, spec, ph, h_final, new_states, routes

class generate(nn.Module):
    def __init__(self, model, tokenizer, length, tmp, topk, penalty):
        super().__init__()
        self.model = model
        self.tokenizer = tokenizer
        self.length = length
        self.tmp = max(tmp, 1e-6)
        self.topk = topk
        self.penalty = penalty

    @torch.no_grad()
    def forward(self, prompt, active4=512):
        self.model.eval()
        device = next(self.model.parameters()).device
        input_ids = self.tokenizer.encode(prompt)
        tokens = torch.tensor([input_ids], dtype=torch.long, device=device)
        lru_state = [None] * len(self.model.layers)

        vocab = getattr(self.model, 'vocab', None)
        if vocab is None:
            # fallback for compiled/wrapped modules
            vocab = self.model.embed.num_embeddings

        print('\nmodel: ', end='', flush=True)
        history = []
        pen_indices = torch.arange(16, device=device)
        decay = torch.exp(-pen_indices / 3.0) * self.penalty

        for _ in range(self.length):
            out = self.model(tokens, lru_states=lru_state, active4=active4, training=False)
            logits1 = out[0][:, -1, :]
            spec_logits_list = out[1]
            lru_state = out[4]

            # 1. Repetition Penalty
            if len(history) > 0:
                h_slice = torch.tensor(history[-16:], device=device)
                logits1[0].index_add_(0, h_slice, -decay[:len(history[-16:])])
                token_counts = torch.bincount(torch.tensor(history[-192:], device=device), minlength=vocab)
                logits1[0] -= (token_counts.float() ** 1.1) * 0.15

            # 2. Dynamic Temperature via Entropy
            probs_check = F.softmax(logits1 / 2.0, dim=-1)
            entropy = -torch.sum(probs_check * torch.log(probs_check + 1e-9))
            dtmp = torch.clamp(self.tmp + (1.0 / (entropy + 0.5)), self.tmp, 1.5)
            logits1 = logits1 / dtmp

            # 3. Top-K Filtering
            top_v, _ = torch.topk(logits1, self.topk)
            logits1[logits1 < top_v[:, [-1]]] = -65504.0

            # 4. Sampling & Speculative Acceptance
            probs = F.softmax(logits1, dim=-1)
            next_token_tensor = torch.multinomial(probs, num_samples=1)
            next_token = next_token_tensor.item()

            accepted_tokens = [next_token]
            history.append(next_token)
            print(self.tokenizer.decode([next_token]), end='', flush=True)

            for future_logits in spec_logits_list:
                f_logits = future_logits[:, -1, :]
                f_probs = F.softmax(f_logits, dim=-1)
                conf, best_token = torch.max(f_probs, dim=-1)
                cost = 1.0 / (conf.item() + 1e-5)
                if cost <= 2.0:
                    t_idx = best_token.item()
                    accepted_tokens.append(t_idx)
                    history.append(t_idx)
                    print(self.tokenizer.decode([t_idx]), end='', flush=True)
                else:
                    break

            tokens = torch.tensor([[accepted_tokens[-1]]], dtype=torch.long, device=device)

        return history

