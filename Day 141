def pad(x, target=512):
    if not isinstance(x, torch.Tensor):
        return x
    if x.ndim == 0:
        return x
    current_size = x.shape[-1]
    pad_amount = target - current_size
    if pad_amount > 0:
        return F.pad(x, (0, pad_amount))
    return x
    #return torch.where(pad_amount > 0, x_padded, x)

