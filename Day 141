def love(tokenizer_instance, path, save_path, rules):
    # 1. Rules Handling
    if not os.path.exists(rules):
        with open(path, "r", encoding="utf-8") as f:
            sample_text = f.read(50 * 1024 * 1024).lower() # Smaller 10MB sample for rules
        tokenizer_instance.train(sample_text)
        with open(rules, 'wb') as f:
            pickle.dump(tokenizer_instance, f)
    else:
        with open(rules, 'rb') as f:
            tokenizer_instance = pickle.load(f)
    # 2. Ultra-Light Binary Streaming
    bin_temp = save_path.replace(".npy", ".bin")
    print(f"Streaming {os.path.basename(path)} to disk (1MB chunks)...")
    with open(path, "r", encoding="utf-8") as f_in, open(bin_temp, "wb") as f_out:
        while True:
            # We use small 1MB chunks to keep the Python list overhead tiny
            chunk = f_in.read(50 * 1024 * 1024) 
            if not chunk:
                break
            # Encode and immediately write to file
            encoded_list = tokenizer_instance.encode(chunk.lower())
            tokens = np.array(encoded_list, dtype=np.uint16)
            tokens.tofile(f_out)
            # Clear intermediate objects
            del encoded_list
            del tokens
            # We don't print too many dots to save console memor
    # 3. Finalize to .npy without loading into RAM
    # We use memory mapping to move the data from .bin to .npy
    raw_data = np.fromfile(bin_temp, dtype=np.uint16)
    np.save(save_path, raw_data)
    if os.path.exists(bin_temp):
        os.remove(bin_temp)
    print(f"\n[SAVED] {save_path}")
    del raw_data
    gc.collect()
    # Return ONLY the tokenizer
    return tokenizer_instance

