if __name__ == "__main__":
    device = 'cuda' if torch.cuda.is_available() else 'cpu'
    N_SIZE = 512
    K_SIZE = 32
    T_SIZE = ((2*math.pi*math.sqrt(3)) / math.log(10)*4) / math.sqrt(N_SIZE)
    L_SIZE = 4
    dt = T_SIZE / L_SIZE
    model = TrueFuzzyUniverse3D(N=N_SIZE, K=K_SIZE, device=device)
    
    # Используем AdamW с чуть более высоким шагом (lr=0.02) для быстрого выхода из плато
    optimizer = torch.optim.AdamW(model.parameters(), lr=0.003, weight_decay=1e-4)
    scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(optimizer, mode='min', factor=0.5, patience=5)

    any_raw_data = torch.randn(N_SIZE, device=device) 
    input_angles = torch.tanh(any_raw_data) * 3.14159
    
    target_angles = -1.0 * input_angles
    target_complex = torch.exp(1j * target_angles)

    print("--- СТАРТ УСПЕШНОГО ОБУЧЕНИЯ ГЕОМЕТРИИ ---")
    
    for epoch in range(1000):
        predicted_complex = model(input_angles, num_layers=L_SIZE, dt=dt)
        
        # Комплексный Евклидов лосс
        loss = torch.mean(torch.abs(predicted_complex - target_complex) ** 2)
        
        optimizer.zero_grad()
        loss.backward()
        
        # Зажим градиентов для защиты стабильности экспоненты
        torch.nn.utils.clip_grad_norm_(model.parameters(), max_norm=1.0)
        
        optimizer.step()
        scheduler.step(loss.item())

        if (epoch + 1) % 5 == 0 or epoch == 0:
            print(f"Эпоха {epoch+1:02d} | Комплексный Loss = {loss.item():.6f}")
