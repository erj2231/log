import torch
import torch.nn as nn
import math

class TrueFuzzyUniverse3D(nn.Module):
    def __init__(self, N=512, device='cpu', K=32, ):
        super().__init__()
        self.N = N
        self.device = device
        self.K = K
        self.B = N // K
        
        # Логарифмический спектр (Метрика нечеткого пространства)
        log_spectrum = torch.logspace(start=0, end=-1, steps=K, base=10.0, device=device)
        std_matrix = log_spectrum.unsqueeze(1) * log_spectrum.unsqueeze(0)
        self.register_buffer('space_metric', std_matrix.unsqueeze(0).repeat(self.B, 1, 1))
        
        # Увеличиваем начальный масштаб весов, чтобы вывести систему из сонного состояния (плато)
        self.X_raw = nn.Parameter(torch.randn(self.B, self.K, self.K, dtype=torch.complex64, device=device) * 0.1)
        self.Y_raw = nn.Parameter(torch.randn(self.B, self.K, self.K, dtype=torch.complex64, device=device) * 0.1)
        self.Z_raw = nn.Parameter(torch.randn(self.B, self.K, self.K, dtype=torch.complex64, device=device) * 0.1)

    def forward(self, input_angles, num_layers=4, dt=0.2):
        # Инициализируем состояние как чистую диагональную матрицу фаз
        # Теперь входные данные явно присутствуют на диагонали с самого начала!
        state = torch.diag(torch.exp(1j * input_angles))

        diag_phases = torch.exp(1j * input_angles).view(self.B, self.K)
        block_state = torch.diagonal_scatter(
            torch.zeros(self.B, self.K, self.K, dtype=torch.complex64, device=self.device),
            diag_phases, dim1=-2, dim2=-1
        )
        
        # Одеваем наши квантовые координаты в лог-метрику и делаем Эрмитовыми
        X = (self.X_raw + self.X_raw.conj().transpose(-2, -1)) * self.space_metric
        Y = (self.Y_raw + self.Y_raw.conj().transpose(-2, -1)) * self.space_metric
        Z = (self.Z_raw + self.Z_raw.conj().transpose(-2, -1)) * self.space_metric
        
        for _ in range(num_layers):
            # Квантовые коммутаторы (вихревое некоммутативное смешивание)
            G = (torch.bmm(X, block_state) - torch.bmm(block_state, X)) + \
                (torch.bmm(Y, block_state) - torch.bmm(block_state, Y)) + \
                (torch.bmm(Z, block_state) - torch.bmm(block_state, Z))
            
            G = -1j * G
            G = 0.5 * (G + G.conj().transpose(-2, -1))

            # Самый быстрый способ посчитать экспоненту / Кэли "в один клик"
            L, V = torch.linalg.eigh(G)  # Разложение: L - вектор [N], V - матрица [N, N]

            # Теперь экспонента от вектора L берется мгновенно (как LUT):
            L_exp = torch.exp(1j * dt * L)  # Векторная операция O(N)

            # Собираем унитарную матрицу обратно за два быстрых умножения O(N^3):
            U = torch.bmm(V * L_exp.unsqueeze(-2), V.conj().transpose(-2, -1))
            state = torch.bmm(U, block_state)
            
        blended_blocks = state.mean(dim=-1)
        blended = blended_blocks.flatten()
        eps = 1e-8
        out_trig = blended / (torch.abs(blended) + eps)

        return out_trig

