            probs = F.softmax(next_token_logits, dim=-1)
            spec1 = torch.multinomial(probs, num_samples=1)
            history.append(spec1.item())

            if logits2 is not None:
                spec2 = logits2[:, -1, :].argmax(-1, keepdim=True)
