def loadbalance(routes, experts, training=False):
    valid_routes = [r for r in routes if r is not None]
    if not valid_routes: return 0
    allroutes = torch.cat([r.view(-1, experts) for r in valid_routes])
    importance = allroutes.mean(dim=0)
    if training:
        load = allroutes.mean(dim=0)
    else:
        indices = torch.argmax(allroutes, dim=-1)
        load = torch.zeros(experts, device=allroutes.device)
        load.scatter_add_(0, indices, torch.ones_like(indices, dtype=torch.float))
        load = load / load.sum()
    return experts * torch.sum(importance * load)

