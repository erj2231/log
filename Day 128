class rms(nn.Module):
    def __init__(self, dim, eps=1e-4):
        super().__init__()
        self.eps = eps
        self.weight = nn.Parameter(torch.ones(dim))
    
    def forward(self, x, active4=None):
        normx = x * torch.rsqrt(x.pow(2).mean(-1, keepdim=True) + self.eps)
        if active4 != x.shape[-1]:
            active4 = x.shape[-1]
        return normx * self.weight[:active4]

class fsqlora(nn.Module):
    def __init__(self, base_linear, rank=8, alpha=256, levels=[8, 5, 5]):
        super().__init__()
        self.base_linear = base_linear
        self.levels = levels
        self.rank = rank
        self.scaling = alpha / rank
        self.norm = rms(base_linear.in_features)
        self.learnable = nn.Parameter(torch.tensor(-0.1))
        # LoRA params
        self.loraa = nn.Parameter(torch.empty(base_linear.in_features, rank))
        self.lorab = nn.Parameter(torch.empty(rank, base_linear.out_features))
        # radix
        basis = torch.ones(len(levels), dtype=torch.long)
        for i in range(1, len(levels)):
            basis[i] = basis[i - 1] * levels[i - 1]
        self.register_buffer("basis", basis)
        nn.init.kaiming_uniform_(self.loraa, a=math.sqrt(5))
        nn.init.normal_(self.lorab, std=1e-3)

    def quantize_val(self, x, levels):
        maxval = (levels[0] - 1) / 2
        curscale = torch.exp(self.learnable)
        scale_factor = (levels[0] / (curscale + 1e-6)) 
        x_scaled = x * scale_factor
        # Clamp and round to the nearest discrete level
        zq = torch.round(torch.clamp(x_scaled, -maxval, maxval))
        return (x + (zq - x).detach()) / scale_factor

    def forward(self, x, out_slice=None, in_slice=None):
        w = self.base_linear.weight 
        b = self.base_linear.bias
        out_f = out_slice if out_slice is not None else x.shape[0]
        in_f = in_slice if in_slice is not None else x.shape[1]
        xnorm = self.norm(x, active4=in_f)  
        x_in = xnorm[..., :in_f]
        w = w[:out_f, :in_f]
        if b is not None:
            b = b[:out_f]
        safelearn = torch.clamp(self.learnable, -5.0, 5.0)
        curscale = torch.exp(safelearn)
        wscale = 16.0 / (curscale + 1e-6)
        wscaled = w * wscale
        z_q = torch.round(torch.clamp(wscaled, -10.0, 10.0))
        wq = (wscaled + (z_q - wscaled).detach()) / wscale
        # loraa is [In, Rank], x_in is [..., In] -> res_a is [..., Rank]
        res_a = x_in @ self.loraa[:in_f, : ]
        if self.training:
            p = 0.1
            mask = (torch.rand_like(res_a) > p).float()
            res_a = (res_a * mask) / (1 - p)
        lora_out = (res_a @ self.lorab[:, :out_f]) * self.scaling
        # -----------------------
        output = F.linear(x_in, wq, b) + lora_out
        return output

class mrrope(nn.Module):
    def __init__(self, rdim, len=384):
        super().__init__()
        # all spectrum
        inv_freq = 1.0 / (10000 ** (torch.arange(0, rdim, 2).float() / rdim))
        # range of len
        t = torch.arange(len).float()
        # putting range onto that spectrum
        freqs = torch.outer(t, inv_freq)
        # preparing for both cos and sin
        emb = torch.cat((freqs, freqs), dim=-1)
        # registering static universe
        self.register_buffer("cos", emb.cos().view(1, len, 1, rdim))
        self.register_buffer("sin", emb.sin().view(1, len, 1, rdim))
    
    def rotatehalf(self, x, c, s):
        # chunk much faster than interleaved
        x1, x2 = x.chunk(2, dim=-1)
        # multiplying everything in cat is much more tactical
        return torch.cat([x1 * c - x2 * s, x2 * c + x1 * s], dim=-1)
    
    def forward(self, q, k):
        B, T, H, D = q.shape
        # Ensure we don't exceed the precomputed buffer length
        # and ensure the cos/sin dimensions match the query dimension D
        cos = self.cos[:, :T, :, :D].to(q.dtype)
        sin = self.sin[:, :T, :, :D].to(q.dtype)
        
        # Because we chunk(2) in rotatehalf, we need the cos/sin 
        # for the chunked size, which is D // 2
        c_chunk, _ = cos.chunk(2, dim=-1)
        s_chunk, _ = sin.chunk(2, dim=-1)
        
        return self.rotatehalf(q, c_chunk, s_chunk), self.rotatehalf(k, c_chunk, s_chunk)

class newmla(nn.Module):
    def __init__(self, emb, n_heads=8, latent_dim=64, rope_dim=32):
        super().__init__()
        self.n_heads = n_heads
        # dim on 1 head
        self.head_dim = emb // n_heads
        self.rope_dim = rope_dim
        # norm before up
        self.norm = rms(emb)
        # Wrapping projections in fsqlora to enable LoRA adapters + Quantized base
        self.kv_down = fsqlora(nn.Linear(emb, latent_dim, bias=False))
        self.kv_up = fsqlora(nn.Linear(latent_dim, n_heads * (self.head_dim + rope_dim + self.head_dim), bias=False))
        # better to init one big then split
        self.q_proj = fsqlora(nn.Linear(emb, n_heads * (self.head_dim + rope_dim), bias=False))
        self.out_proj = nn.Linear(n_heads * self.head_dim, emb, bias=False)
        # 0.1 as i want normal distribution in kvdown
        nn.init.xavier_uniform_(self.kv_down.base_linear.weight, gain=1.0)
        nn.init.xavier_uniform_(self.kv_up.base_linear.weight)
        nn.init.xavier_uniform_(self.q_proj.base_linear.weight)
        # final residual
        nn.init.xavier_uniform_(self.out_proj.weight, gain=1.0)

    def forward(self, x, rope_obj, active4, grid_levels=[8, 5, 5]):
        # x: [B, T, emb]
        current_latent = max(32, active4 // 4)
        B, T, _ = x.shape
        x = x[:, :, :active4]

        # quantize activations (leave FSQ behavior intact)
        x_q = self.norm(x, active4)
        x_q = self.kv_down.quantize_val(x_q, levels=[16])

        # latent kv
        kv_latent = self.kv_down(x_q, out_slice=current_latent, in_slice=active4)
        kv_latent = self.kv_down.quantize_val(kv_latent, levels=[16])
        
        total_needed_per_head = self.head_dim + self.rope_dim + self.head_dim # 224
        total_width = self.n_heads * total_needed_per_head

        # project to per-head K/V
        kv = self.kv_up(kv_latent, out_slice=total_width, in_slice=current_latent)
        kv = kv.view(B, T, self.n_heads, total_needed_per_head)
        k_content, k_pe, v = torch.split(kv, [self.head_dim, self.rope_dim, self.head_dim], dim=-1)

        total_q_width = self.n_heads * (self.head_dim + self.rope_dim)
        # project Q from x (not from kv)
        q = self.q_proj(x_q, out_slice=total_q_width, in_slice=active4)
        q = q.view(B, T, self.n_heads, -1)
        q_content, q_pe = torch.split(q, [self.head_dim, self.rope_dim], dim=-1)

        # RoPE on positional parts
        q_pe, k_pe = rope_obj(q_pe, k_pe)

        # combine content+pos
        q = torch.cat([q_content, q_pe], dim=-1).transpose(1, 2)  
        # [B, H, T, head_dim+rope_dim]
        k = torch.cat([k_content, k_pe], dim=-1).transpose(1, 2)
        v = v.transpose(1, 2)  # [B, H, T, head_dim]

        current_head_dim = q_content.size(-1)
        dynamic_scale = 1.0 / math.sqrt(current_head_dim + self.rope_dim)
        q_scaled = q * dynamic_scale

        # attention
        out = F.scaled_dot_product_attention(q_scaled, k, v, is_causal=True, scale=1.0)
        out = out.transpose(1, 2).reshape(B, T, self.n_heads * self.head_dim)

        # project back to model dim (slice to active4)
        out = F.linear(out, self.out_proj.weight[:active4, :self.n_heads * current_head_dim], None)
        return x + out

class moe(nn.Module):
    def __init__(self, emb, experts, latent_dim=None):
        super().__init__()
        self.experts = experts
        self.kv_dim = latent_dim or (emb // 4)
        # Wrapping each expert's up and down projection in fsqlora
        # This allows each expert to have its own LoRA adapter
        self.w_q = nn.ModuleList([
            fsqlora(nn.Linear(emb, self.kv_dim, bias=False))
            for _ in range(experts)
        ])
        self.w_o = nn.ModuleList([
            fsqlora(nn.Linear(self.kv_dim, emb, bias=False))
            for _ in range(experts)
        ])
        # regulatory parameter for router
        self.bias = nn.Parameter(torch.zeros(8))
        self.norm = rms(self.kv_dim)
        nn.init.constant_(self.bias, -1.0)
        with torch.no_grad():
            for e in range(experts):
                nn.init.xavier_uniform_(self.w_q[e].base_linear.weight, gain=0.1)
                nn.init.xavier_uniform_(self.w_o[e].base_linear.weight, gain=0.02)

    def forward(self, x, route, active4=None, grid_levels=[2, 2], *, training=False):
        # x: [B, T, C]
        x = x[:, :, :active4]
        B, T, C = x.shape
        x_flat = x.view(-1, C)
        kv_slice = max(32, active4 // 4)

        if training == True:
            probs = route
        else:
            idx = route.view(-1)
            probs = torch.zeros(idx.numel(), self.experts, device=x.device, dtype=x.dtype)
            probs.scatter_(1, idx.unsqueeze(1), 1.0)

        expert_outputs = []
        for e in range(self.experts):
            x_q = self.w_q[e].quantize_val(x_flat, levels=[16, 16, 16])
            wq_q = self.w_q[e](x_q[:, :active4], out_slice=kv_slice, in_slice=active4)
            mid = F.silu(self.norm(wq_q, active4=kv_slice))
            wo_q = self.w_o[e](mid, out_slice=active4, in_slice=kv_slice)
            expert_outputs.append(wo_q.unsqueeze(1))

        all_outs = torch.cat(expert_outputs, dim=1)  # [B*T, Experts, active4]
        gate_flat = probs.view(B * T, self.experts, 1)
        final_output = torch.bmm(gate_flat.transpose(1, 2), all_outs)
        return x + final_output.view(B, T, active4)

class lnn(nn.Module):
    def __init__(self, emb):
        super().__init__()
        # emb * 2 as it takes two inputs
        # Wrapping in fsqlora for bitted weights + LoRA
        self.dt = fsqlora(nn.Linear(emb * 2, emb))
        # Accessing .base_linear.weight because of the wrapper
        nn.init.xavier_uniform_(self.dt.base_linear.weight)
        # -2 is a good gating
        nn.init.constant_(self.dt.base_linear.bias, -2.0)

    def forward(self, h, combined_context, active4=None):
        h = h[:, :, :active4]
        combined_context = combined_context[:, :, :active4]
        combined = torch.cat([combined_context, h], dim=-1)
        # Get adapted weight with specific Matryoshka slicing
        # active4*2 for the concatenated input, active4 for output
        wq_dt = self.dt(combined, out_slice=active4, in_slice=active4*2)
        dt = torch.sigmoid(wq_dt)
        # [384] + ([384] - [384]) * [384] -> [384]
        # tanh used for bigger spectrum
        return h + (-h + torch.tanh(combined_context)) * dt

class swigluznn(nn.Module):
    def __init__(self, emb):
        super().__init__()
        hidden_dim = int(8/3 * emb)
        # better to init one and split then two
        self.w_combined = fsqlora(nn.Linear(emb, hidden_dim * 2, bias=False))
        self.w_down = fsqlora(nn.Linear(hidden_dim, emb, bias=False))
        with torch.no_grad():
            # 0.1 for gate
            nn.init.xavier_uniform_(self.w_combined.base_linear.weight[:hidden_dim], gain=0.1)
            nn.init.xavier_uniform_(self.w_down.base_linear.weight, gain=0.02)
            # 1.0 for up
            nn.init.xavier_uniform_(self.w_combined.base_linear.weight[hidden_dim:])

    def forward(self, x, active4=None):
        active_hidden = int(8/3 * active4)
        target_out = active_hidden * 2
        combined = self.w_combined(x[:, :, :active4], out_slice=target_out, in_slice=active4)
        if combined.shape[-1] < 2:
            gate = up = combined
        else:
            gate, up = torch.chunk(combined, 2, dim=-1)
        # [B, T, 682] * [B, T, 682] -> [B, T, 682]
        # silu used for smoothness
        hff = F.silu(gate) * up        
        curr_hff_width = hff.shape[-1]
        # Down project
        wq_down = self.w_down(hff, out_slice=active4, in_slice=curr_hff_width)
        # [B, T, 682] @ [682, 256] -> [B, T, 256]
        return x + wq_down

class lru(nn.Module):
    def __init__(self, emb, d_state=16):
        super().__init__()
        self.emb = emb
        self.d_state = d_state
        self.dt_rank = 16
        # Grouped conv stays standard as it's small/specialized
        self.conv1d = nn.Conv1d(emb, emb, kernel_size=4, groups=emb, padding=3)
        # Wrap projections
        self.x_proj = fsqlora(nn.Linear(emb, self.dt_rank + d_state * 2, bias=False))
        self.dt_proj = fsqlora(nn.Linear(self.dt_rank, emb, bias=True))
        self.A_log = nn.Parameter(torch.log(torch.arange(1, emb + 1).float()))
        self.state_norm = rms(emb) 
        self.changeable = nn.Parameter(torch.tensor(1.0))
        nn.init.normal_(self.dt_proj.base_linear.weight, mean=0.0, std=0.5)
        nn.init.dirac_(self.conv1d.weight)
        nn.init.orthogonal_(self.x_proj.base_linear.weight, gain=0.02)
        nn.init.constant_(self.dt_proj.base_linear.bias, -0.5)
        with torch.no_grad():
            self.A_log.copy_(torch.log(torch.linspace(0.001, 0.1, emb)))

    def forward(self, x, nextstate=None, training=False, active4=None):
        B_size, T, E = x.shape
        x_sliced = x[:, :, :active4]
        # Convolutional path
        # Slicing conv weights manually as fsqlora isn't applied to conv here
        x_conv = F.conv1d(
            x_sliced.transpose(1, 2), 
            self.conv1d.weight[:active4, :1, :], 
            bias=self.conv1d.bias[:active4] if self.conv1d.bias is not None else None,
            groups=active4, 
            padding=3
        ).transpose(1, 2)
        x_active = F.silu(x_conv[:, :T, :active4]) # Ensure T length matches
        # 1. Project to ranks (B, C, DT)
        total_db_dim = self.dt_rank + self.d_state + self.d_state
        x_db = self.x_proj(x_active, out_slice=total_db_dim, in_slice=active4)
        dt_raw, b_vals, c_vals = torch.split(x_db, [self.dt_rank, self.d_state, self.d_state], dim=-1)
        # 2. Project DT to embedding dim
        dtlinear = self.dt_proj(dt_raw[..., :active4], out_slice=active4, in_slice=None)
        dt = F.softplus(dtlinear * 0.1)
        a_log_sliced = torch.clamp(self.A_log[:active4].float(), max=-2.0)
        A = -torch.exp(a_log_sliced)
        if training:
            log_decay = dt * A.view(1, 1, -1) 
            cum_decay = torch.cumsum(log_decay, dim=1)
            cum_decay = torch.clamp(cum_decay, min=-50.0, max=50.0)
            
            # Match the active4 width for all parameters
            dt_active = dt[:, :T, :active4]
            b_active = b_vals[:, :, :active4]
            c_active = c_vals[:, :, :active4]

            term = (x_active * dt_active).unsqueeze(-1) * b_active.unsqueeze(-2)
            max_decay = cum_decay.max(dim=1, keepdim=True)[0]
            u_discounted = term * torch.exp(-(cum_decay - max_decay)).unsqueeze(-1)
            history = torch.cumsum(u_discounted, dim=1)
            decay = torch.exp(cum_decay - max_decay).unsqueeze(-1)
            state = history * decay

            if nextstate is not None:
                newstate = nextstate.unsqueeze(1) * torch.exp(cum_decay).unsqueeze(-1)
                combinedstate = state + newstate
            else:
                combinedstate = state
            laststate = combinedstate[:, -1, :].detach()

            combinedstate = self.state_norm(combinedstate)
            y = (combinedstate * c_active[:, :, :active4].unsqueeze(2)).sum(dim=-1)
            return x + 0.01 * y[:, :T, :active4] * self.changeable, laststate
        else:            
            if nextstate is None:
                state = torch.zeros(B_size, active4, self.d_state, device=x.device, dtype=x.dtype)
            else:
                state = nextstate
            y_out = torch.empty(B_size, T, active4, device=x.device, dtype=x.dtype)
            for t in range(T): 
                dt_t = dt[:, t, :].unsqueeze(-1) 
                b_t = b_vals[:, t, :].unsqueeze(1) 
                c_t = c_vals[:, t, :].unsqueeze(-1) 
                x_t = x_active[:, t, :].unsqueeze(-1)
                
                decay = torch.exp(dt_t * A.view(1, -1, 1))
                decay = torch.clamp(decay, min=0.0, max=0.99)
                state = state * decay + (dt_t * x_t * b_t)
                normstate = self.state_norm(state)

                y_t = torch.matmul(normstate, c_t).squeeze(-1)
                y_out[:, t, :] = y_t
            return x + 0.01 * y_out * self.changeable, state

class heads(nn.Module):
    def __init__(self, emb, vocab, spec_count):
        super().__init__()
        self.embed = nn.Embedding(vocab, emb)
        self.spec_count = spec_count
        # Norms
        self.norm_f = rms(emb)
        self.norm_mtp = rms(emb)
        # Wrapped Projections
        self.gate = fsqlora(nn.Linear(emb, emb))
        self.pred_state = fsqlora(nn.Linear(emb, emb))
        # Multi-Token Prediction Heads
        self.spec_heads = nn.ModuleList([
            fsqlora(nn.Linear(emb, emb)) for _ in range(spec_count)
        ])
        # Inits
        nn.init.normal_(self.embed.weight, mean=0.0, std=0.02)
        nn.init.xavier_uniform_(self.gate.base_linear.weight, gain=0.1)
        nn.init.constant_(self.gate.base_linear.bias, -1.0)
        for h in self.spec_heads:
            nn.init.xavier_uniform_(h.base_linear.weight, gain=0.1)

    def opo_linear(self, x, weight, chunks=4):
        # [V, E] chunked for memory efficiency
        vocab_chunks = torch.chunk(weight, chunks, dim=0)
        logits = [F.linear(x, w_c) for w_c in vocab_chunks]
        return (torch.cat(logits, dim=-1))
    
    def forward(self, h_final, i4=None, active4=None, grid_levels=[8, 5, 5]):
        # [B, T, active4]
        # Quantize inputs using the helper from one of the fsqlora instances
        h_norm = self.gate.quantize_val(self.norm_f(h_final[:, :, :active4], active4), levels=[16, 16, 16])
        i4_norm = self.gate.quantize_val(self.norm_f(i4[:, :, :active4], active4), levels=[16, 16, 16])
        # 1. Gate Logic
        wq_gate = self.gate(h_norm, out_slice=active4, in_slice=active4)
        g = torch.sigmoid(wq_gate)
        # before operation
        self.pred_state.learnable.data = torch.clamp(self.pred_state.learnable.data, -2.0, 2.0)
        # 2. Prediction State
        ph = self.pred_state(i4_norm, out_slice=active4, in_slice=active4)
        # MTP State
        curr_mtp_state = self.norm_mtp(i4_norm + (ph * g), active4)
        curr_mtp_state = self.gate.quantize_val(curr_mtp_state, levels=grid_levels)
        # Classifier (Weight Tying)
        logits = self.opo_linear(curr_mtp_state, self.embed.weight[:, :active4])
        logits = torch.clamp(logits, -30.0, 30.0)
        # 3. MTP Chain
        mtp_logits_chain = []
        for spec_layer in self.spec_heads:
            wq_spec = spec_layer(curr_mtp_state, out_slice=active4, in_slice=active4)
            next_state = torch.tanh(wq_spec)
            curr_mtp_state = self.gate.quantize_val(self.norm_mtp(next_state, active4), levels=grid_levels)
            step_logits = self.opo_linear(curr_mtp_state, self.embed.weight[:, :active4])
            mtp_logits_chain.append(torch.clamp(step_logits, -30.0, 30.0))
        return logits, mtp_logits_chain, ph, h_norm

class layer(nn.Module):
    def __init__(self, i, emb, experts):
        super().__init__()
        self.i = i
        self.lnn = lnn(emb)
        self.norm1 = rms(emb)
        self.norm2 = rms(emb)
        self.rope = mrrope(rdim=32)
        self.smallparam = nn.Parameter(torch.ones(emb) * 0.1)
        # Expert vs SwiGLU logic
        if i % 2 == 0:
            self.is_expert = True
            self.branch = moe(emb, experts)
            self.router = nn.Linear(emb, experts, bias=False)
            nn.init.orthogonal_(self.router.weight, gain=0.01)
        else:
            self.is_expert = False
            self.branch = swigluznn(emb)
        # Global (MLA) vs Local (LRU) logic
        if i % 3 == 0:
            self.is_global = True
            self.mla = newmla(emb)
        else:
            self.is_global = False
            self.lrussd = lru(emb)

    def forward(self, h, lrustate, tau, training=False, active4=None):
        resscale = (128.0 / float(active4)) ** 2
        hsliced = h[:, :, :active4]
        if active4 == 384:
            hsliced = torch.clamp(hsliced, -4.0, 4.0)
        elif active4 == 256:
            hsliced = torch.clamp(hsliced, -6.0, 6.0)
        elif active4 == 128:
            hsliced = torch.clamp(hsliced, -8.0, 8.0)
        else:
            hsliced = torch.clamp(hsliced, -10.0, 10.0)

        # 1. Context Branch
        if self.is_global:
            h_context = self.mla(hsliced, self.rope, active4)
            if torch.isnan(h_context).any() and active4 == 384:
                print(f"!!! CRITICAL: MLA exploded at layer {self.i}")
            next_state = None
        else:
            h_context, next_state = self.lrussd(hsliced, nextstate=lrustate, training=training, active4=active4)
            if torch.isnan(h_context).any() and active4 == 384:
                print(f"!!! CRITICAL: LRU exploded at layer {self.i}")
        h_context = torch.clamp(h_context, -6.0, 6.0)
        h_context = hsliced + (h_context * resscale)
        h_context = self.norm1(h_context, active4)

        # 2. Feedforward / MoE Branch
        if self.is_expert:
            router_logits = F.linear(h_context, self.router.weight[:8, :active4], bias=self.router.bias[:8])
            scale_factor = 8.0
            router_logits = router_logits / scale_factor
            router_logits = torch.clamp(router_logits, -8.0, 8.0)
            if training:
                # differentiable routing probabilities
                #route = F.gumbel_softmax(router_logits + self.branch.bias, tau=tau, hard=False)
                gumbels = -torch.empty_like(router_logits).exponential_().log()
                half_stable = (router_logits + gumbels) / (tau + 1e-8) 
                logits_stable = half_stable +  + self.branch.bias
                route = F.softmax(logits_stable, dim=-1)
                route = (route + 1e-6) / (1.0 + 1e-6 * route.size(-1))
            else:
                route = router_logits.argmax(-1)
            combined_context = self.branch(hsliced, route, active4, training=training)
        else:
            combined_context = self.branch(hsliced, active4)
            route = None
        combined_context = torch.clamp(combined_context, -6.0, 6.0)
        hffn = h_context + (combined_context * resscale)
        hffn = self.norm2(hffn, active4)

        # 3. Liquid Fusion
        h_liquid = self.lnn(h_context, hffn, active4)
        l1 = h_context + (h_liquid * self.smallparam[:active4])
        return l1, next_state, route

class model(nn.Module):
    def __init__(self, vocab, emb, n_layers, n_experts, spec_count=2):
        super().__init__()
        self.vocab = vocab
        self.emb = emb
        self.embed = nn.Embedding(vocab, emb)
        self.layers = nn.ModuleList([layer(i, emb, n_experts) for i in range(n_layers)])
        self.heads = heads(emb, vocab, spec_count)
        nn.init.normal_(self.embed.weight, std=0.02)
        self.mtpmix = nn.Parameter(torch.ones(emb) * 0.5)

    def forward(self, x, lru_states=None, tau=1.0, active4=384, training=False):
        # Scale embedding
        h = self.embed(x) * (active4 ** 0.5)
        h = h[:, :, :active4]
        if lru_states is None:
            lru_states = [None] * len(self.layers)

        routes = []
        new_states = []

        # First layer pass to establish i4 (residual anchor)
        h, ns, r = self.layers[0](h, lru_states[0], tau, training=training, active4=active4)
        i4 = h.clone()
        new_states.append(ns)
        if r is not None:
            routes.append(r)

        for i in range(1, len(self.layers)):
            h, ns, r = self.layers[i](h, lru_states[i], tau, training=training, active4=active4)
            new_states.append(ns)
            if r is not None:
                routes.append(r)

        # MTP Mixing
        h = h + (i4 * self.mtpmix[:active4])

        # Heads
        l1, spec, ph, h_final = self.heads(h, i4, active4)                
        return l1, spec, ph, h_final, new_states, routes

class generate(nn.Module):
    def __init__(self, model, tokenizer, length, tmp, topk, penalty):
        super().__init__()
        self.model = model
        self.tokenizer = tokenizer
        self.length = length
        self.tmp = max(tmp, 1e-6)
        self.topk = topk
        self.penalty = penalty

    @torch.no_grad()
    def forward(self, prompt, active4=384):
        self.model.eval()
        device = next(self.model.parameters()).device
        input_ids = self.tokenizer.encode(prompt)
        tokens = torch.tensor([input_ids], dtype=torch.long, device=device)
        lru_state = [None] * len(self.model.layers)

        vocab = getattr(self.model, 'vocab', None)
        if vocab is None:
            # fallback for compiled/wrapped modules
            vocab = self.model.embed.num_embeddings

        print('\nmodel: ', end='', flush=True)
        history = []
        pen_indices = torch.arange(16, device=device)
        decay = torch.exp(-pen_indices / 3.0) * self.penalty

        for _ in range(self.length):
            out = self.model(tokens, lru_states=lru_state, active4=active4, training=False)
            logits1 = out[0][:, -1, :]
            spec_logits_list = out[1]
            lru_state = out[4]

            # 1. Repetition Penalty
            if len(history) > 0:
                h_slice = torch.tensor(history[-16:], device=device)
                logits1[0].index_add_(0, h_slice, -decay[:len(history[-16:])])
                token_counts = torch.bincount(torch.tensor(history[-192:], device=device), minlength=vocab)
                logits1[0] -= (token_counts.float() ** 1.1) * 0.15

            # 2. Dynamic Temperature via Entropy
            probs_check = F.softmax(logits1 / 2.0, dim=-1)
            entropy = -torch.sum(probs_check * torch.log(probs_check + 1e-9))
            dtmp = torch.clamp(self.tmp + (1.0 / (entropy + 0.5)), self.tmp, 1.5)
            logits1 = logits1 / dtmp

            # 3. Top-K Filtering
            top_v, _ = torch.topk(logits1, self.topk)
            logits1[logits1 < top_v[:, [-1]]] = -65504.0

            # 4. Sampling & Speculative Acceptance
            probs = F.softmax(logits1, dim=-1)
            next_token_tensor = torch.multinomial(probs, num_samples=1)
            next_token = next_token_tensor.item()

            accepted_tokens = [next_token]
            history.append(next_token)
            print(self.tokenizer.decode([next_token]), end='', flush=True)

            for future_logits in spec_logits_list:
                f_logits = future_logits[:, -1, :]
                f_probs = F.softmax(f_logits, dim=-1)
                conf, best_token = torch.max(f_probs, dim=-1)
                cost = 1.0 / (conf.item() + 1e-5)
                if cost <= 2.0:
                    t_idx = best_token.item()
                    accepted_tokens.append(t_idx)
                    history.append(t_idx)
                    print(self.tokenizer.decode([t_idx]), end='', flush=True)
                else:
                    break

            tokens = torch.tensor([[accepted_tokens[-1]]], dtype=torch.long, device=device)

        return history

