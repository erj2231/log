def process_parquets(input_pattern, output_file):
    print(f"Starting Parquet merge into: {output_file}")
    with open(output_file, "w", encoding="utf-8") as out:
        for f in glob.glob(input_pattern):
            print(f"  Processing: {os.path.basename(f)}")
            df = pd.read_parquet(f)
            for text_item in df.iloc[:, 0]:
                s_text = str(text_item)
                if len(s_text) > 10:
                    out.write(s_text + "\n")
            del df
            gc.collect()

def process_txts(input_pattern, output_file):
    print(f"Starting TXT merge into: {output_file}")
    # List of files to ignore to avoid infinite loops
    ignore_list = [tiny_out, openweb_out, wiki_out]
    
    with open(output_file, "w", encoding="utf-8") as out:
        for f in glob.glob(input_pattern):
            # Check if current file is one of our outputs
            if any(os.path.abspath(f) == os.path.abspath(i) for i in ignore_list):
                continue
            
            print(f"  Processing: {os.path.basename(f)}")
            with open(f, \"r\", encoding=\"utf-8\") as f_in:
                for line in f_in:
                    out.write(line)
                out.write("\n")

