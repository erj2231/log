    yb2 = batch_raw[2].to('cpu', non_blocking=True)
    
    # so autocast is automated float switches
    scales = [64, 128, 256, 384]
    accumloss = torch.tensor(0.0, device=xb.device, requires_grad=True)
    for mdim in scales:
        l1, spec_chain, ph, hf, _, routes = gpt(xb, tau=curr_tau, active4=mdim, training=True)
        loss_t1 = F.cross_entropy(l1.reshape(-1, 4096), yb1.reshape(-1))
        if torch.isnan(loss_t1) or torch.isinf(loss_t1):
            print(f'!!! Scale {mdim} exploded! Skipping...')
            continue
        accumloss = accumloss + loss_t1 * (((1.0 / len(scales)) + (mdim / scales[-1])) / 2)

        if spec_chain:
            for idx, slogits in enumerate(spec_chain):
                specloss = F.cross_entropy(slogits.reshape(-1, vocab), yb2[:, :l1.size(1)].reshape(-1))
                accumloss = accumloss + (0.5 * specloss)

        if i > 25:
            # differentiable aux loss (routes are probs in training=True)
            aux_loss = loadbalance(routes, experts=8, training=True)
            router_probs = torch.cat([r.reshape(-1, experts) for r in routes if r is not None], dim=0)
            # router regularizer (encourage non-peaky / non-exploding routing)
            z_loss = torch.logsumexp(router_probs.clamp_min(1e-9).log(), dim=-1).pow(2).mean()
            accumloss = accumloss + (0.1 * aux_loss + 0.01 * z_loss)

        del l1, spec_chain, ph, hf, loss_t1
    
    accumloss = accumloss / len(scales)
