            entropy = -torch.sum(probs_check * torch.log(probs_check + 1e-9))
            dynamic_tmp = torch.clamp(entropy / 2.5, 0.4, 1.2)
            next_token_logits = raw_logits / dynamic_tmp

            for i, prev_token in enumerate(reversed(history[-8:])):
