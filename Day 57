class rms(nn.Module):
    def __init__(self, dim, eps=1e-6):
        super().__init__()
        self.eps = eps
        self.weight = nn.Parameter(torch.ones(dim))
    
    def forward(self, x):
        normx = x * torch.rsqrt(x.pow(2).mean(-1, keepdim=True) + self.eps)
        return normx * self.weight

class mrrope(nn.Module):
    def __init__(self, dim, len=512):
        super().__init__()
        inv_freq = 1.0 / (10000 ** (torch.arange(0, dim, 2).float() / dim))
        t = torch.arange(len).float()
        freqs = torch.outer(t, inv_freq)
        emb = torch.cat((freqs, freqs), dim=-1)
        self.register_buffer("cos", emb.cos().view(1, len, 1, dim))
        self.register_buffer("sin", emb.sin().view(1, len, 1, dim))
    
    def rotatehalf(self, x):
        x1, x2 = x.chunk(2, dim=-1)
        return torch.cat((-x2, x1), dim=-1)
    
    def apply(self, q, k):
        T = q.shape[1]
        cos = self.cos[:, :T, :, :]
        sin = self.sin[:, :T, :, :]
        q = (q * cos) + (self.rotatehalf(q) * sin)
        k = (k * cos) + (self.rotatehalf(k) * sin)
        return q, k

class hashedmla(nn.Module):
    def __init__(self, emb, nbuckets=8):
        super().__init__()
        self.kv_dim = emb // 4
        self.head_dim = emb // nbuckets
        self.lshproj = nn.Parameter(torch.randn(emb, nbuckets))

    def forward(self, q, k, v):
        q_b = torch.argmax(q @ self.lshproj, dim=-1)
        k_b = torch.argmax(k @ self.lshproj, dim=-1)
        mask = (q_b.unsqueeze(-1) == k_b.unsqueeze(-2))
        attn = (q @ k.transpose(-2, -1) * (self.kv_dim ** -0.5))
        attn = attn.masked_fill(~mask.to(torch.bool), -1e9)
        weights = F.softmax(attn, dim=-1)
        return weights @ v

class moe(nn.Module):
    def __init__(self, emb, experts):
        super().__init__()
        self.experts = experts
        kv_dim = emb // 4
        self.w_q = nn.Parameter(torch.empty(experts, emb, kv_dim))
        self.w_o = nn.Parameter(torch.empty(experts, kv_dim, emb))
        with torch.no_grad():
            for e in range(experts):
                nn.init.xavier_uniform_(self.w_q[e])
                nn.init.xavier_uniform_(self.w_o[e])
    
    def forward(self, x, route_soft):
        q_experts = torch.einsum('bti,eio->bteo', x, self.w_q)
        out_experts = torch.einsum('bteo,eok->btek', q_experts, self.w_o)
        out = (out_experts * route_soft.unsqueeze(-1)).sum(dim=2)
        return out

class lnn(nn.Module):
    def __init__(self, emb):
        super().__init__()
        self.dt = nn.Parameter(torch.randn(emb) * 0.1)
        self.ambient = nn.Parameter(torch.ones(1))
        self.tau = nn.Parameter(torch.ones(emb))

    def forward(self, h, combined_context):
        dt = self.dt * torch.sigmoid(self.ambient)
        time_constant = F.softplus(self.tau).clamp(min=1e-2) 
        dh_dt = (-h + combined_context) / time_constant
        h_liquid = h + dh_dt * dt
        return h_liquid

class swigluznn(nn.Module):
    def __init__(self, emb):
        super().__init__()
        self.wgate = nn.Linear(emb, int(8/3 * emb))
        self.wup = nn.Linear(emb, int(8/3 * emb))
        self.wdown = nn.Linear(int(8/3 * emb), emb)

    def forward(self, hin, h_liquid):
        gate = self.wgate(h_liquid)
        up = self.wup(h_liquid)
        hff = F.silu(gate) * up
        return self.wdown(hff)

class lru(nn.Module):
    def __init__(self, emb):
        super().__init__()
        self.lrugate = nn.Linear(emb, emb)

    def forward(self, lrustate, hnorm):
        outputs = []
        curr_state = lrustate
        for t in range(hnorm.size(1)):
            x_t = hnorm[:, t, :]
            lambda_lru = torch.sigmoid(self.lrugate(x_t))
            curr_state = lambda_lru * x_t + (1 - lambda_lru) * curr_state
            outputs.append(curr_state.unsqueeze(1))
        h_mem = torch.cat(outputs, dim=1)
        return h_mem, curr_state

class heads(nn.Module):
    def __init__(self, emb, vocab):
        super().__init__()
        self.embed = nn.Embedding(vocab, emb)
        self.pred_state = nn.Linear(emb, emb)
        self.head_t1 = nn.Linear(emb, vocab, bias=False)
        self.head_t2 = nn.Linear(emb, vocab, bias=False)
        self.norm_f = rms(emb)
        self.combiner = nn.Linear(emb * 3, emb)

    def forward(self, h_final, i4=None):
        h_final = self.norm_f(h_final)
        ph = self.pred_state(h_final)
        l2 = None
        if i4 is not None:
            l2 = self.head_t2(self.norm_f(i4))
        combined = torch.cat([h_final, i4, ph], dim=-1)
        h_flat = self.combiner(combined)
        logits = self.head_t1(h_flat)
        return logits, l2, ph, h_final

class layer(nn.Module):
    def __init__(self, i, emb, experts):
        super().__init__()
        self.i = i
        self.lru = lru(emb)
        self.lnn = lnn(emb)
        self.norm = rms(emb)
        self.mrrope = mrrope(emb, len=48)
        self.mla = hashedmla(emb, nbuckets=8)
        if i % 3 == 0:
            self.is_expert = True
            self.branch = moe(emb, experts)
            self.router = nn.Linear(emb, experts)
            nn.init.orthogonal_(self.router.weight, gain=0.01)
        else:
            self.is_expert = False
            self.branch = swigluznn(emb)

    def forward(self, h, lrustate, route=None):
        hnorm = self.norm(h)
        h_mem, next_state = self.lru(lrustate, hnorm)
        h_attn = self.mla(h_mem, h_mem, h_mem)
        h_attn, _ = self.mrrope.apply(h_attn, h_attn)
        if self.is_expert:
            combined_context = self.branch(h_attn, route)
        else:
            combined_context = self.branch(h_attn, h_attn) 
        h_liquid = self.lnn(h_attn, combined_context)
        return h + h_liquid, next_state, route

class model(nn.Module):
    def __init__(self, vocab, emb, n_layers, n_experts):
        super().__init__()
        self.emb = emb
        self.embed = nn.Embedding(vocab, emb)
        self.vocab = vocab
        self.n_experts = n_experts
        self.layers = nn.ModuleList([layer(i, emb, n_experts) for i in range(n_layers)])
        self.heads = heads(emb, vocab)

    def forward(self, x, step=None, lru=None, tau=1.0):
        h = self.embed(x)
        if lru is None: 
            lru = [torch.zeros(x.size(0), self.emb, device=x.device) for _ in range(len(self.layers))]
        routes, new_states, i4 = [], [], None
        for i, l in enumerate(self.layers):
            route = None
            if l.is_expert:
                logits = l.router(h)
                if self.training:
                    logits = logits + torch.randn_like(logits) * 0.02
                route = F.gumbel_softmax(logits, tau=tau, hard=not self.training)
                routes.append(route)
            h, state_out, _ = l(h, lru[i], route)
            new_states.append(state_out)
            if i == 1: i4 = h.clone()
        l1, l2, ph, h_final = self.heads(h, i4)
        return l1, l2, ph, h_final, new_states, routes

