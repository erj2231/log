def val(model, data, batch, block, iters, device, dtype):
    model.eval()
    losses = torch.zeros(iters)
    print(f'-> VALIDATING: Sampling {iters} batches...')
    for k in range(iters):
        xb, yb1, _ = get_batch(data, block, batch)
        # doing in 16 if possible
        with torch.amp.autocast(device_type=device.type, dtype=dtype):
            logits, _, _, _, _, _ = model(xb, step=0, tau=0.1)
            loss = F.cross_entropy(logits.view(-1, 4096), yb1.view(-1))
            losses[k] = loss.item()
        # freeing xb and yb1 spaces now
        del xb, yb1
    model.train()
    return losses.mean()

class rms(nn.Module):
    def __init__(self, dim, eps=1e-6):
        super().__init__()
        self.eps = eps
        # regulatory param to give space for model
        self.weight = nn.Parameter(torch.ones(dim))
    
    def forward(self, x):
        # rsqrt pow2 can be done only in float32
        x = x.to(torch.float32)
        # [B, T, 256] -> [B, T, 256]
        normx = x * torch.rsqrt(x.pow(2).mean(-1, keepdim=True) + self.eps)
        return normx.to(torch.float16) * self.weight

class mrrope(nn.Module):
    def __init__(self, rdim, len=512):
        super().__init__()
        # all spectrum
        inv_freq = 1.0 / (10000 ** (torch.arange(0, rdim, 2).float() / rdim))
        # range of len
        t = torch.arange(len).float()
        # putting range onto that spectrum
        freqs = torch.outer(t, inv_freq)
        # preparing for both cos and sin
        emb = torch.cat((freqs, freqs), dim=-1)
        # registering static universe
        self.register_buffer("cos", emb.cos().view(1, len, rdim))
        self.register_buffer("sin", emb.sin().view(1, len, rdim))
    
    def rotatehalf(self, x, c, s):
        # chunk much faster than interleaved
        x1, x2 = x.chunk(2, dim=-1)
        # multiplying everything in cat is much more tactical
        return torch.cat([x1 * c - x2 * s, x2 * c + x1 * s], dim=-1)
    
    def forward(self, q, k):
        T = q.shape[1]
        # [1, T, 384] -> [1, T, 1, 384]
        # by :T we save ram
        cos = self.cos[:, :T, :].unsqueeze(2).to(q.dtype)
        sin = self.sin[:, :T, :].unsqueeze(2).to(q.dtype)
        # [B, T, H, 384] * [1, T, 1, 384] -> [B, T, H, 384]
        return self.rotatehalf(q, cos, sin), self.rotatehalf(k, cos, sin)

class newmla(nn.Module):
    def __init__(self, emb, n_heads=8, latent_dim=64, rope_dim=32):
        super().__init__()
        self.n_heads = n_heads
        # dim on 1 head
        self.head_dim = emb // n_heads
        self.rope_dim = rope_dim
        # norm before up
        self.norm = rms(emb)
        self.kv_down = nn.Linear(emb, latent_dim, bias=False)
        self.kv_up = nn.Linear(latent_dim, n_heads * (self.head_dim + rope_dim + self.head_dim), bias=False)
        # better to init one big then split
        self.q_proj = nn.Linear(emb, n_heads * (self.head_dim + rope_dim), bias=False)
        self.out_proj = nn.Linear(n_heads * self.head_dim, emb, bias=False)
        # ultimate scale of content + position
        self.scale = (self.head_dim + rope_dim) ** -0.5
        # 0.1 as i want normal distribution in kvdown
        nn.init.xavier_uniform_(self.kv_down.weight, gain=0.1)
        nn.init.xavier_uniform_(self.kv_up.weight)
        nn.init.xavier_uniform_(self.q_proj.weight)
        # final residual
        nn.init.xavier_uniform_(self.out_proj.weight, gain=0.02)

    def forward(self, x, rope_obj):
        # [B, T, 384]
        B, T, _ = x.shape
        # [B, T, 384] * [384, 64] -> [B, T, 64] * [64, H * (32 + 32 + 32)] -> [B, T, H, 96]
        # compressing x down to save ram
        kv_up = self.kv_up(self.norm(self.kv_down(x))).view(B, T, self.n_heads, -1)
        # [B, T, H, 96] -> [B, T, H, 32] + [B, T, H, 32] + [B, T, H, 32]
        k_content, k_pe, v = torch.split(kv_up, [self.head_dim, self.rope_dim, self.head_dim], dim=-1)
        # [B, T, 384] * [384, H * (32 + 32)] -> [B, T, H, 64]
        q_up = self.q_proj(x).view(B, T, self.n_heads, -1)
        # [B, T, H, 64] -> [B, T, H, 32] + [B, T, H, 32]
        q_content, q_pe = torch.split(q_up, [self.head_dim, self.rope_dim], dim=-1)
        # i only rotate pe part
        q_pe, k_pe = rope_obj(q_pe, k_pe)
        # [B, T, H, 32] + [B, T, H, 32] -> [B, T, H, 64]
        q, k = torch.cat([q_content, q_pe], dim=-1), torch.cat([k_content, k_pe], dim=-1)
        # [B, T, H, 64] -> [B, H, T, 64]
        q = q.transpose(1, 2)
        # [B, T, H, 64] -> [B, H, T, 64]
        k = k.transpose(1, 2)
        # [B, T, H, 32] -> [B, H, T, 32]
        v = v.transpose(1, 2) 
        # [B, H, T, T] * [B, H, T, 32] -> [B, H, T, 32]
        # sdpa replaces softmax, mask and operations like einsum and scale
        out = F.scaled_dot_product_attention(
            q, k, v, 
            is_causal=True, 
            scale=self.scale
        ) 
        # [B, H, T, 32] -> [B, T, H, 32] -> [B, T, 384]
        # transpose+reshape are glued to next and they only change stride
        return self.out_proj(out.transpose(1, 2).reshape(B, T, -1))

class moe(nn.Module):
    def __init__(self, emb, experts):
        super().__init__()
        self.experts = experts
        # again on 1 head
        kv_dim = emb // 4
        self.w_q = nn.Parameter(torch.empty(experts, emb, kv_dim))
        self.w_o = nn.Parameter(torch.empty(experts, kv_dim, emb))
        # added regulatory parameter for router to choose
        self.bias = nn.Parameter(torch.zeros(experts))
        # 1.0 is ideal for router: not 0 and no 2 like gates
        nn.init.constant_(self.bias, -1.0)
        with torch.no_grad():
            for e in range(experts):
                nn.init.xavier_uniform_(self.w_q[e])
                # again 0.02 used for final residual layer
                nn.init.xavier_uniform_(self.w_o[e], gain=0.02)
    
    def forward(self, x, route_soft):
        B, T, C = x.shape
        probs = F.softmax((route_soft + self.bias), dim=-1)
        # [B, T, E] -> [B, T, 2]
        # using top2 to free up ram
        top2_probs, top2_indices = torch.topk(probs, 2, dim=-1)
        # / sum to normalize
        top2_probs = top2_probs / top2_probs.sum(dim=-1, keepdim=True)
        # [B, T, C] -> [B*T, C]
        x_flat = x.view(-1, C)
        final_output = torch.zeros_like(x_flat)
        for i in range(2): 
            # [B, T, 2] -> [B*T]
            # collapsing them
            indices = top2_indices[:, :, i].view(-1) 
            # [B, T, 2] -> [B*T, 1]
            weights = top2_probs[:, :, i].view(-1, 1) 
            # sorting to premap indices
            sorted_experts, perm_indices = torch.sort(indices)
            x_sorted = x_flat[perm_indices]
            w_q_selected = self.w_q[sorted_experts]
            w_o_selected = self.w_o[sorted_experts]
            # [B*T, 1, C] * [B*T, C, D] -> [B*T, 1, D]
            # blunt but very fast
            mid = torch.bmm(x_sorted.unsqueeze(1), w_q_selected)
            # [B*T, 1, D] * [B*T, D, C] -> [B*T, C]
            res = torch.bmm(F.silu(mid), w_o_selected).squeeze(1)
        inv_indices = torch.empty_like(perm_indices)
        # unsorting
        inv_indices[perm_indices] = torch.arange(len(perm_indices), device=x.device)
        # summing batches
        final_output += res[inv_indices] * weights
        # [B*T, C] -> [B, T, C]
        return final_output.view(B, T, C)

class lnn(nn.Module):
    def __init__(self, emb):
        super().__init__()
        # emb * 2 as it takes two inputs
        self.dt = nn.Linear(emb * 2, emb)
        nn.init.xavier_uniform_(self.dt.weight)
        # -2 is a good gating
        nn.init.constant_(self.dt.bias, -2.0)

    def forward(self, h, combined_context):
        combined = torch.cat([combined_context, h], dim=-1)
        # [384] @ [384] -> [384]
        dt = torch.sigmoid(self.dt(combined))
        # [384] + ([384] - [384]) * [384] -> [384]
        # tanh used for bigger spectrum
        return h + (-h + torch.tanh(combined_context)) * dt

class swigluznn(nn.Module):
    def __init__(self, emb):
        super().__init__()
        hidden_dim = int(8/3 * emb)
        # better to init one and split then two
        self.w_combined = nn.Linear(emb, hidden_dim * 2, bias=False)
        self.w_down = nn.Linear(hidden_dim, emb, bias=False)
        with torch.no_grad():
            # 0.1 for gate
            nn.init.xavier_uniform_(self.w_combined.weight[:hidden_dim], gain=0.1)
            nn.init.xavier_uniform_(self.w_down.weight, gain=0.02)
            # 1.0 for up
            nn.init.xavier_uniform_(self.w_combined.weight[hidden_dim:])

    def forward(self, x):
        combined = self.w_combined(x) 
        gate, up = torch.chunk(combined, 2, dim=-1)
        # [B, T, 682] * [B, T, 682] -> [B, T, 682]
        # silu used for smoothness
        hff = F.silu(gate) * up
        # [B, T, 682] @ [682, 256] -> [B, T, 256]
        return self.w_down(hff)

class lru(nn.Module):
    def __init__(self, emb, d_state=16):
        super().__init__()
        self.emb = emb
        # adding d_state features on top
        self.d_state = d_state
        # compressing into 16
        self.dt_rank = 16
        # diagonal which allows smooth curves
        self.conv1d = nn.Conv1d(emb, emb, kernel_size=4, groups=emb, padding=3)
        # one very big weight then split
        self.x_proj = nn.Linear(emb, self.dt_rank + d_state * 2, bias=False)
        self.dt_proj = nn.Linear(self.dt_rank, emb, bias=True)
        # arange is not used but its a placeholder
        self.A_log = nn.Parameter(torch.log(torch.arange(1, emb + 1).float()))
        self.state_norm = rms(d_state) 
        # normal as xavier is too big
        nn.init.normal_(self.dt_proj.weight, mean=0.0, std=0.01)
        # dirac gives exact copy of input
        nn.init.dirac_(self.conv1d.weight)
        # orthogonal and 0.02 cuz flowing and should be energetic
        nn.init.orthogonal_(self.x_proj.weight, gain=0.02)
        # again gating
        nn.init.constant_(self.dt_proj.bias, -2.0)
        with torch.no_grad():
            # this way i make spectrum
            self.A_log.copy_(torch.log(torch.linspace(0.001, 0.1, emb)))

    def forward(self, x, training=False):
        # [B, T, 384]
        B_size, T, E = x.shape
        # [B, T, 384] * [384, 384] -> [B, 384, T] -> [B, T, 384]
        x_conv = self.conv1d(x.transpose(1, 2)).transpose(1, 2)[:, :T, :]
        x_active = F.silu(x_conv)
        # [B, T, 384] * [384, 48] -> [B, T, 48]]
        x_db = self.x_proj(x_active)
        # [B, T, 48] -> [B, T, 16] + [B, T, 16] + [B, T, 16]
        dt_raw, b_vals, c_vals = torch.split(x_db, [self.dt_rank, self.d_state, self.d_state], dim=-1)
        # [B, T, 16] * [16, 384] -> [B, T, 384]
        # clamping on exp
        dt = torch.exp(self.dt_proj(dt_raw)).clamp(max=0.1)
        # no clamping as it would break it
        A = -torch.exp(self.A_log.float()) 
        if training:
            log_decay = dt * A.view(1, 1, -1) 
            # [B, T, E, 1]
            # cumsum is horizontal pass so 0T
            cum_decay = torch.cumsum(log_decay, dim=1).unsqueeze(-1) 
            # [B, T, E, 1] * [B, T, 1, 16] -> [B, T, E, 16]
            # how slow it takes input and how much of it
            term = (x_active * dt).unsqueeze(-1) * b_vals.unsqueeze(2) 
            # [B ,T, E, 16] * [B, T, E, 1] -> [B, T, E, 16]
            u_discounted = term * torch.exp(-cum_decay).unsqueeze(-1)
            # sum of all inputs
            history = torch.cumsum(u_discounted, dim=1)
            # [B, T, E, 16] * [B, T, E, 1] -> [B, T, E, 16]
            # put history on scale
            state = history * torch.exp(cum_decay).unsqueeze(-1)
            # [B, T, E, 16] * [B, T, 1, 16] -> [B, T, E]
            # how much it needs
            y = (state * c_vals.unsqueeze(2)).sum(dim=-1)
            return y
        # if inference and i dont need tons in parallel
        else:            
            state = torch.zeros(B_size, E, self.d_state, device=x.device, dtype=x.dtype)
            y_out = torch.empty(B_size, T, E, device=x.device, dtype=x.dtype)
            for t in range(T): 
                # [B, 384, 1]
                dt_t = dt[:, t, :].unsqueeze(-1) 
                # [B, 1, 16]
                b_t = b_vals[:, t, :].unsqueeze(1) 
                # [B, 16, 1]
                c_t = c_vals[:, t, :].unsqueeze(-1) 
                # [B, 384, 1]
                x_t = x_active[:, t, :].unsqueeze(-1)
                # [B, T, 384] * [384, 1] -> [B, T, 1]
                decay = torch.exp(dt_t * A.view(1, -1, 1))
                # [B, 384, 16] * [B, 384, 1] -> [B, 384, 16]
                state = state * decay + (dt_t * x_t * b_t)
                state = self.state_norm(state) 
                # [B, 384, 16] * [B, 16, 1] -> [B, 384, 1] -> [B, 384]
                # in this case vertically builds words up
                y_t = torch.matmul(state, c_t).squeeze(-1)
                y_out[:, t, :] = y_t
            return y_out

class heads(nn.Module):
    def __init__(self, emb, vocab):
        super().__init__()
        self.embed = nn.Embedding(vocab, emb)
        self.pred_state = nn.Linear(emb, emb)
        self.head_t1 = nn.Linear(emb, vocab, bias=False)
        self.norm_f = rms(emb)
        self.norm_mtp = rms(emb)
        self.gate = nn.Linear(emb, emb)
        # embeds std 0.02 to be sure
        nn.init.normal_(self.embed.weight, mean=0.0, std=0.02)
        # gates should be 0.1
        nn.init.xavier_uniform_(self.gate.weight, gain=0.1)
        # -1 for gate
        nn.init.constant_(self.gate.bias, -1.0)
        nn.init.xavier_uniform_(self.pred_state.weight)
        # weight tying
        self.tw = self.embed.weight

    def forward(self, h_final, i4=None):
        # [B, T, 384] -> [B, T, 384]
        h_norm = self.norm_f(h_final)
        # [B, T, 384] * [384, 384] -> [B, T, 384]
        # use linear only when embs tied
        logits = F.linear(h_norm, self.embed.weight)
        # clamp
        logits = torch.clamp(logits, -30.0, 30.0)
        l2 = None
        if i4 is not None:
            # here i need strong gate
            g = torch.sigmoid(self.gate(h_norm))
            # [B, T, 384] * [384, 384] -> [B, T, 384]
            ph = self.pred_state(h_norm)
            # [B, T, 384] * [B, T, 384] -> [B, T, 384]
            mtp_latent = self.norm_mtp(self.norm_f(i4) + (ph * g))
            # here too when tied
            l2 = F.linear(mtp_latent, self.embed.weight)
            #clamping logits to not explode
            l2 = torch.clamp(l2, -30.0, 30.0)
        return logits, l2, ph, h_norm

class layer(nn.Module):
    def __init__(self, i, emb, experts):
        super().__init__()
        self.i = i
        self.lnn = lnn(emb)
        self.norm1 = rms(emb)
        self.norm2 = rms(emb)
        self.rope = mrrope(rdim=32)
        # small adjustable param for input at the end
        self.smallparam = nn.Parameter(torch.ones(emb) * 0.1)

        # every third moe
        if i % 2 == 0:
            self.is_expert = True
            self.branch = moe(emb, experts)
            self.router = nn.Linear(emb, experts)
            nn.init.orthogonal_(self.router.weight, gain=0.01)
        else:
            self.is_expert = False
            self.branch = swigluznn(emb)

        # every last long memory otherwise small
        if i % 3 == 0:
            self.is_global = True
            self.mla = newmla(emb)
        else:
            self.is_global = False
            self.lrussd = lru(emb)

    def forward(self, h, lrustate, tau, training=False):
        hnorm1 = self.norm1(h)
        hnorm2 = self.norm2(h)
        if self.is_global:
            # [B, T, 384] -> [B, T, 384]
            h_context = self.mla(hnorm1, self.rope)
            next_state = None
        else:
            # [B, T, 384] -> [B, T, 384]
            h_context, next_state = self.lrussd(lrustate, hnorm1)
        h_context = h + h_context
        if self.is_expert:
            # [B, T, 256], [B, T, 8] -> [B, T, 256]
            logits = self.router(hnorm2)
            # clamping logits
            logits = torch.clamp(logits, -30.0, 30.0)
            if training:
                route = F.gumbel_softmax(logits, tau=tau, hard=not training)
            else:
                route = logits.argmax(-1)
            combined_context = self.branch(hnorm2, route)
        else:
            # [B, T, 256] -> [B, T, 256]
            combined_context = self.branch(hnorm2, hnorm2) 
            route = None
        # [B, T, 256], [B, T, 256] -> [B, T, 256]
        h_liquid = self.lnn(h_context, combined_context)
        return h + (h_liquid * self.smallparam), next_state, route

class model(nn.Module):
    def __init__(self, vocab, emb, n_layers, n_experts):
        super().__init__()
        self.emb = emb
        self.embed = nn.Embedding(vocab, emb)
        self.vocab = vocab
        self.n_experts = n_experts
        # importing layers
        self.layers = nn.ModuleList([layer(i, emb, n_experts) for i in range(n_layers)])
        self.heads = heads(emb, vocab)
        nn.init.normal_(self.embed.weight, std=0.02)
        self.heads.head_t1.weight = nn.Parameter(self.embed.weight)
        # adjustable i4 input param
        self.mtpmix = nn.Parameter(torch.ones(emb) * 0.5)

    def forward(self, x, lru=None, tau=1.0):
        # [B, T] @ [V, 256] -> [B, T, 256]
        # scaling embs up
        h = self.embed(x) * (self.emb ** 0.5)
        if lru is None: lru = [None] * len(self.layers)
        routes = []
        new_states = []
        # i4 is additional data for logits2
        i4_accum = []
        for i, l in enumerate(self.layers):
            route = None
            if i < 2:
                i4_accum.append(h)
            # last layer checkpoint
            if self.training and i > 2 and i % 3 == 0: 
                h, next_state, route = checkpoint(layer, h, lru[i], tau, use_reentrant=False)
            else:
                h, next_state, route = layer(h, lru[i], tau)
            if route is not None: routes.append(route)
            new_states.append(next_state) 
        i4 = i4_accum[0] + (i4_accum[1] * self.mtpmix)
        # [B, T, 256], [B, T, 256] -> [B, T, V]
        l1, l2, ph, h_final = self.heads(h, i4)
        return l1, l2, ph, h_final, new_states, routes

class generate(nn.Module):
    def __init__(self, model, model2, tokenizer, length, tmp, topk, penalty):
        super().__init__()
        self.model = model
        self.model2 = model2
        self.tokenizer = tokenizer
        self.length = length
        # eps alternative
        self.tmp = max(tmp, 1e-6) 
        self.topk = topk
        self.penalty = penalty

    @torch.no_grad()
    def forward(self, prompt):
        self.model.eval()
        device = next(self.model.parameters()).device
        input_ids = self.tokenizer.encode(prompt)
        tokens = torch.tensor([input_ids], dtype=torch.long, device=device)
        # if none then its just pass
        lru_state = [None] * len(self.model.layers)
        print('\nmodel: ', end='', flush=True)
        history = []
        # make a range of last 16
        pen_indices = torch.arange(16, device=device)
        # making penalties range
        decay = torch.exp(-pen_indices / 3.0) * self.penalty

        for _ in range(self.length):
            out = self.model(tokens, lru=lru_state)
            logits1 = out[0][:, -1, :]
            logits2 = out[1][:, -1, :]
            new_lru = out[4]

            if len(history) > 0:
                h_slice = torch.tensor(history[-16:], device=device)
                # putting hslice on penalties range
                logits1[0].index_add_(0, h_slice, -decay[:len(history)])
                # global 128 penalty
                token_counts = torch.bincount(torch.tensor(history[-128:], device=device), minlength=self.model.vocab)
                logits1[0] -= (token_counts.float() ** 1.1) * 0.15

            # flattening logits
            probs_check = F.softmax(logits1 / 2.0, dim=-1)
            # we sum probs and weirdness
            entropy = -torch.sum(probs_check * torch.log(probs_check + 1e-9))
            # by 1 / we balance entropy
            dtmp = torch.clamp(self.tmp + (1.0 / (entropy + 0.5)), self.tmp, 1.5)
            logits1 = logits1 / dtmp
            # hard mask alternative
            top_v, top_i = torch.topk(logits1, self.topk) 
            logits1[logits1 < top_v[:, [-1]]] = -65504.0
            
            probs = F.softmax(logits1, dim=-1)
            spec1 = torch.multinomial(probs, num_samples=1)
            history.append(spec1.item())
            print(self.tokenizer.decode([spec1.item()]), end='', flush=True)

            # for logits2
            if logits2 is not None and len(history) < self.length:
                # here is quantized one
                if self.model2 is not None:
                    spec2 = logits2.argmax(-1, keepdim=True)
                    v_out = self.model(spec1, lru=new_lru)
                    actual_next = v_out[0][:, -1, :].argmax(-1, keepdim=True)
                    if spec2 == actual_next and spec2.item() not in history[-4:]:
                        next_id = spec2.item()
                        history.append(next_id)
                        print(self.tokenizer.decode([next_id]), end='', flush=True)
                        tokens = spec2
                        lru_state = v_out[4]
                        continue
                # if no small model yet then looking at confidence
                else:
                    future_probs = F.softmax(logits2, dim=-1)
                    conf, spec2 = torch.max(future_probs, dim=-1, keepdim=True)
                    if conf.item() > 0.9 and spec2.item() not in history[-4:]:
                        next_id = spec2.item()
                        history.append(next_id)
                        print(self.tokenizer.decode([next_id]), end='', flush=True)
                        tokens = spec2
                        lru_state = new_lru
                        continue

            tokens = spec1
            lru_state = new_lru
        return history

